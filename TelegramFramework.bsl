			ТипЗнч(ДанныеJSON.result) = Тип("Структура") Тогда
			
			Возврат;
		КонецЕсли;    			
	Исключение
		
		ОбщийСервер.Пауза(1);
		
		Попытка
			
			Ответ = Соединение.ОтправитьДляОбработки(HTTPЗапрос);
			
			ОтветСтрокой = Ответ.ПолучитьТелоКакСтроку();
			
			Если Не Лев(ОтветСтрокой, 1) = "{" Или
				Не Прав(ОтветСтрокой, 1) = "}" Тогда
				
				Возврат;
			КонецЕсли;
			
			ЧтениеJSON = Новый ЧтениеJSON();
			ЧтениеJSON.УстановитьСтроку(ОтветСтрокой);
			ДанныеJSON = ПрочитатьJSON(ЧтениеJSON);
			ЧтениеJSON.Закрыть();
			
			Если ДанныеJSON.Свойство("ok") И
				ДанныеJSON.ok = Истина И
				ДанныеJSON.Свойство("result") И
				ТипЗнч(ДанныеJSON.result) = Тип("Структура") Тогда
				
				Возврат;
			КонецЕсли; 
		Исключение
			СообщениеОбОшибке = ОписаниеОшибки();
			Telegram.ОтправитьИнформационноеСообщение(511985368,"Подробности ошибки: "+ ИмяБота + Символы.ПС + СообщениеОбОшибке);
		КонецПопытки;
	КонецПопытки;
	
КонецПроцедуры

Процедура ОтправитьСообщениеСФайлом(ИмяБота, TelegramId, MessageId,СтрокаСообщения,Файл)
	
	Если ЗначениеЗаполнено(Файл) Тогда
		
		Запрос = Новый Запрос;
		Запрос.Текст = 
		"ВЫБРАТЬ
		|	Файлы.ИмяФайла КАК ИмяФайла,
		|	Файлы.РасширениеФайла КАК РасширениеФайла
		|ИЗ
		|	РегистрСведений.Файлы КАК Файлы
		|ГДЕ
		|	Файлы.ID = &IDФайла";
		
		Запрос.УстановитьПараметр("IDФайла", Файл);
		Выборка = Запрос.Выполнить().Выбрать();
		
		ДанныеФайла = ФайлыСервер.Прочитать(Файл);
		
		Если Не Выборка.Следующий() Или ДанныеФайла = Неопределено Тогда
			
			ОтправитьВTelegramText(ИмяБота, TelegramId, MessageId, СтрокаСообщения, "", Истина);
		Иначе
			ИмяФайлаДляЗагрузки = ПолучитьИмяВременногоФайла();
			ДанныеФайла.Данные.Записать(ИмяФайлаДляЗагрузки);
			
			Если ОбщийСервер.ЭтоКартинка(Выборка.ИмяФайла) Тогда
				
				ОтправитьВTelegramPhoto(ИмяБота, TelegramId, Выборка.ИмяФайла + "." + Выборка.РасширениеФайла, ИмяФайлаДляЗагрузки, СтрокаСообщения, "");
			Иначе
				ОтправитьВTelegramDocument(ИмяБота, TelegramId, Выборка.ИмяФайла + "." + Выборка.РасширениеФайла, ИмяФайлаДляЗагрузки, СтрокаСообщения, "");
			КонецЕсли;
		КонецЕсли;
	КонецЕсли;
	
КонецПроцедуры

Процедура ОтправитьНапоминаниеВTelegram()
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
	"ВЫБРАТЬ
	|	Задача.Ссылка КАК Ссылка,
	|	Задача.Исполнитель.TelegramId КАК TelegramId
	|ИЗ
	|	Документ.Задача КАК Задача
	|ГДЕ
	|	НЕ Задача.ДатаНапоминания = ДАТАВРЕМЯ(1, 1, 1)
	|	И Задача.ДатаНапоминания <= &ВыбДата
	|	И НЕ Задача.Исполнитель.TelegramId = 0";
	
	Запрос.УстановитьПараметр("ВыбДата", ТекущаяДата());
	
	Выборка = Запрос.Выполнить().Выбрать();
	
	Пока Выборка.Следующий() Цикл
		
		Попытка
			
			ТекстСообщения = "Задача № " + СокрЛП(Выборка.Ссылка);
			
			ОтправитьВTelegramText("Название", Выборка.TelegramId, 0, ТекстСообщения);
			
			ЗадачаОбъект = Выборка.Ссылка.ПолучитьОбъект();
			ЗадачаОбъект.ДатаНапоминания = Дата(1,1,1);
			ЗадачаОбъект.Записать();
			
		Исключение
			
			ЗаписьЖурналаРегистрации("Telegram.ОтправитьНапоминаниеВTelegram", УровеньЖурналаРегистрации.Информация,,,ОписаниеОшибки());
		КонецПопытки;
		
	КонецЦикла;
	
КонецПроцедуры

Процедура ОтправитьСообщенияВTelegram(ИмяБота)
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
	"ВЫБРАТЬ
	|	Сотрудники.TelegramId,
	|	Сообщения.Сотрудник.Наименование КАК Сотрудник,
	|	Сообщения.Сообщение,
	|	Сообщения.IDФайла,
	|	ДиалогиУчастники.Сотрудник КАК УчастникДиалога,
	|	ДиалогиУчастники.ПоследняяОтправкаВTelegram КАК ПоследняяОтправкаВTelegram,
	|	Сообщения.ДатаВМиллисекундах КАК ДатаВМиллисекундах
	|ИЗ
	|	Справочник.Диалоги.Участники КАК ДиалогиУчастники
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Справочник.Пользователи КАК Сотрудники
	|		ПО ДиалогиУчастники.Сотрудник = Сотрудники.Ссылка
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ РегистрСведений.Сообщения КАК Сообщения
	|		ПО (Сообщения.Диалог = &Диалог)
	|			И ДиалогиУчастники.ПоследняяОтправкаВTelegram < Сообщения.ДатаВМиллисекундах
	|			И (ДиалогиУчастники.Сотрудник <> Сообщения.Сотрудник
	|				ИЛИ ДиалогиУчастники.Сотрудник = Сообщения.Сотрудник
	|					И НЕ Сообщения.Telegram)
	|ГДЕ
	|	ДиалогиУчастники.Ссылка = &Диалог
	|	И НЕ Сотрудники.ПометкаУдаления
	|	И НЕ Сотрудники.Архивный
	|	И Сотрудники.TelegramId > 0
	|
	|УПОРЯДОЧИТЬ ПО
	|	ДатаВМиллисекундах
	|ИТОГИ
	|	МАКСИМУМ(ПоследняяОтправкаВTelegram)
	|ПО
	|	УчастникДиалога";
	
	Запрос.УстановитьПараметр("Диалог", Справочники.Диалоги.Основной);
	
	ВыборкаУчастниковДиалога = Запрос.Выполнить().Выбрать(ОбходРезультатаЗапроса.ПоГруппировкам);
	
	Массив = Новый Массив;
	
	Пока ВыборкаУчастниковДиалога.Следующий() Цикл
		
		Массив.Добавить(Новый Структура("Сотрудник,ПоследняяОтправкаВTelegram", ВыборкаУчастниковДиалога.УчастникДиалога, ТекущаяУниверсальнаяДатаВМиллисекундах()));
		
		Если ВыборкаУчастниковДиалога.ПоследняяОтправкаВTelegram = 0 Тогда
			
			Продолжить;
		КонецЕсли;
		
		ВыборкаСообщений = ВыборкаУчастниковДиалога.Выбрать(ОбходРезультатаЗапроса.ПоГруппировкам);
		
		Пока ВыборкаСообщений.Следующий() Цикл
			
			СтрокаСообщения = СокрЛП(ВыборкаСообщений.Сотрудник) + Символы.ПС + СокрЛП(ВыборкаСообщений.Сообщение);
			
			ОтправитьВTelegramText(ИмяБота, ВыборкаСообщений.TelegramId, 0, СтрокаСообщения);
		КонецЦикла;
	КонецЦикла;
	
	Если Массив.Количество() > 0 Тогда
		
		ТекДиалог = Справочники.Диалоги.Основной.ПолучитьОбъект();
		
		Для Каждого СтрокаМассива Из Массив Цикл
			
			ТекСтрока = ТекДиалог.Участники.Найти(СтрокаМассива.Сотрудник, "Сотрудник");
			Если ТекСтрока = Неопределено Тогда
				
				Продолжить;
			КонецЕсли;
			
			ТекСтрока.ПоследняяОтправкаВTelegram = СтрокаМассива.ПоследняяОтправкаВTelegram;
		КонецЦикла;
		
		ТекДиалог.Записать();
	КонецЕсли;
	
КонецПроцедуры

Процедура ОтправитьОповещениеВTelegram(ИмяБота, ТекстОповещения, Сотрудник, ГруппаАдресации = Неопределено, Важное = Ложь, Организация = Неопределено, ПредопределеннаяДатаОтправки = Неопределено) Экспорт
	
	Если ПредопределеннаяДатаОтправки = Неопределено Тогда
		
		ПредопределеннаяДатаОтправки = ТекущаяДата();
	КонецЕсли;
	
	Сотрудники = Новый Массив;
	
	Если ТипЗнч(Сотрудник) = Тип("СправочникСсылка.Пользователи") Тогда
		
		Сотрудники.Добавить(Сотрудник);
	ИначеЕсли ТипЗнч(Сотрудник) = Тип("Массив") Тогда
		
		Для Каждого цСотрудник Из Сотрудник Цикл
			
			Сотрудники.Добавить(цСотрудник);
		КонецЦикла;
	КонецЕсли;
	
	Если ГруппаАдресации <> Неопределено Тогда
		
		Запрос = Новый Запрос;
		
		Если Организация <> Неопределено Тогда
			
			СтрОрганизация = "И Адресация.Организация = &Организация";
			Запрос.УстановитьПараметр("Организация",Организация);
		Иначе
			
			СтрОрганизация = "";
		КонецЕсли;
		
		Запрос.Текст = 
		"ВЫБРАТЬ РАЗЛИЧНЫЕ
		|	Адресация.Пользователь КАК Сотрудник
		|ИЗ
		|	РегистрСведений.НастройкиГруппАдресации КАК Адресация
		|ГДЕ
		|	Адресация.ГруппаАдресации = &Группа
		|	И НЕ Адресация.Пользователь.ПометкаУдаления
		|			И НЕ Адресация.Пользователь.Архивный";
		
		Запрос.УстановитьПараметр("Группа", ГруппаАдресации);
		Выборка = Запрос.Выполнить().Выбрать();
		
		Пока Выборка.Следующий() Цикл
			
			Сотрудники.Добавить(Выборка.Сотрудник);
		КонецЦикла;
	КонецЕсли;
	
	Для Каждого СотрудникСтрока Из Сотрудники Цикл
		
		TelegramId = СотрудникСтрока.TelegramId; 
		
		Если TelegramId > 0 Тогда
			
			ДобавлениеОповещения = РегистрыСведений.TelegramОповещения.СоздатьМенеджерЗаписи();
			ДобавлениеОповещения.TelegramId = TelegramId;
			ДобавлениеОповещения.ВремяОтправки = ТекущаяДата();
			ДобавлениеОповещения.ИмяБота = ИмяБота;
			ДобавлениеОповещения.ТекстСообщения = ТекстОповещения;
			
			ДобавлениеОповещения.Записать(Истина);
		КонецЕсли;
	КонецЦикла;
	
КонецПроцедуры

#КонецОбласти      

#Область МаршрутизацияКомандИГлавноеМеню    

Процедура НачалоРаботы(ИмяБота, TelegramId, MessageId = 0, Сообщение = "Выберите действие:") Экспорт
	
	Запрос = Новый Запрос;
	Запрос.Текст = "ВЫБРАТЬ
	|	TelegramНачальнаяСтраница.TelegramId КАК TelegramId,
	|	TelegramНачальнаяСтраница.ИмяБота КАК ИмяБота,
	|	TelegramНачальнаяСтраница.MessageId КАК MessageId
	|ИЗ
	|	РегистрСведений.TelegramНачальнаяСтраница КАК TelegramНачальнаяСтраница
	|ГДЕ
	|	TelegramНачальнаяСтраница.TelegramId = &TelegramId
	|	И TelegramНачальнаяСтраница.ИмяБота = &ИмяБота";
	Запрос.УстановитьПараметр("TelegramId",TelegramId);
	Запрос.УстановитьПараметр("ИмяБота",ИмяБота);
	Выборка = Запрос.Выполнить().Выбрать();
	
	Если Выборка.Следующий() И Выборка.MessageId > 0 Тогда
		
		ОтправитьВTelegramDeleteMessage(ИмяБота, TelegramId, Выборка.MessageId);
	КонецЕсли;
	
	ТекущееПространство = ПараметрыСеанса.ТекущееПространство;
	
	УдалитьТекущийЗапрос(ИмяБота, TelegramId);
	
	reply_markup = СписокКоманд(ИмяБота, TelegramId, ТекущееПространство);
	
	Если СтрНайти(Сообщение, "Выберите действие:",,1,1) > 0 Тогда
		Если НЕ ТекущееПространство.Пустая() Тогда
			Сообщение = "Текущее пространство: " + Строка(ТекущееПространство) +"."+ Символы.ПС + Сообщение;
		Иначе
			Сообщение = "У вас нет текущих пространств."+ Символы.ПС + Сообщение;
		КонецЕсли;
	КонецЕсли;
	
	ОтветMessageId = ОтправитьВTelegramText(ИмяБота, TelegramId, MessageId, Сообщение, reply_markup, Истина);
	
	Если ОтветMessageId > 0 Тогда
		
		МенеджерЗаписи = РегистрыСведений.TelegramНачальнаяСтраница.СоздатьМенеджерЗаписи();
		МенеджерЗаписи.ИмяБота    = ИмяБота;
		МенеджерЗаписи.TelegramId = TelegramId;
		МенеджерЗаписи.MessageId  = ОтветMessageId;
		МенеджерЗаписи.Записать(Истина);
	КонецЕсли;
	
КонецПроцедуры

Функция СписокКоманд(ИмяБота, TelegramId, ТекущееПространство = Неопределено)
	
	СотрудникЗарегистрированВTelegram = СотрудникЗарегистрированВTelegram(TelegramId);
	МассивПонимаемыхКоманд = ТаблицаПонимаемыхКоманд(ИмяБота, TelegramId).Строки.НайтиСтроки(Новый Структура("АвтоКоманда", Ложь));
	
	Если ТекущееПространство = Неопределено Тогда
		ТекущееПространство = ПараметрыСеанса.ТекущееПространство;
	КонецЕсли;
	
	СтрокаКнопок = "";
	Для Каждого Стр Из МассивПонимаемыхКоманд Цикл
		
		Если Стр.Команда = "Зарегистрироваться" И СотрудникЗарегистрированВTelegram Тогда
			Продолжить;
		КонецЕсли;
		
		Если НЕ Стр.Команда = "Зарегистрироваться" И НЕ СотрудникЗарегистрированВTelegram Тогда
			Продолжить;
		КонецЕсли;
		
		Если Стр.Команда = "РаботаСПространствамиПриРегистрации" И НЕ ТекущееПространство.Пустая() И СотрудникЗарегистрированВTelegram Тогда
			Продолжить;
		КонецЕсли;
		
		Если НЕ Стр.Команда = "РаботаСПространствамиПриРегистрации" И ТекущееПространство.Пустая() И СотрудникЗарегистрированВTelegram Тогда
			Продолжить;
		КонецЕсли;
		
		Если Стр.Команда = "ОтчетПоСпринту" И НЕ СотрудникОтветствененЗаСпринты(TelegramId) И НЕ СотрудникУчаствуетВСпринтах(TelegramId) Тогда
			Продолжить;
		КонецЕсли;     
		
		Кнопка = "[{""text"": """ + Стр.Описание;
		Если Стр.Ссылка = "" Тогда
			Кнопка = Кнопка + """, ""callback_data"": """ + Стр.Имя + """}]";
		Иначе
			Кнопка = Кнопка + """, ""url"": """ + Стр.Ссылка + """}]";
		КонецЕсли;
		
		СтрокаКнопок = СтрокаКнопок + Кнопка + ",";
	КонецЦикла;
	
	Если НЕ ПустаяСтрока(СтрокаКнопок) Тогда
		
		Возврат "{""inline_keyboard"": [" + Лев(СтрокаКнопок, СтрДлина(СтрокаКнопок) - 1) + "]}";
	Иначе
		Возврат Неопределено;
	КонецЕсли;
	
КонецФункции

Функция ТаблицаПонимаемыхКоманд(ИмяБота, TelegramId)
	
	ДеревоЗначений = Новый ДеревоЗначений;
	ДеревоЗначений.Колонки.Добавить("Имя", Новый ОписаниеТипов("Строка"));
	ДеревоЗначений.Колонки.Добавить("Команда", Новый ОписаниеТипов("Строка"));
	ДеревоЗначений.Колонки.Добавить("Описание", Новый ОписаниеТипов("Строка"));
