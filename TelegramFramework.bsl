#Область ПриемИОбработкаФайлов  

// Принимает из Telegram файл
//
// Параметры:
//  ИмяБота     - Строка - Имя бота, из которого пришло сообщение
//  Сообщение   - Структура - Сообщение из Telegram
//
// Возвращаемое значение:
//  Структура
//   * ИмяФайла        - Строка
//   * РасширениеФайла - Строка
//   * Данные          - ДвоичныеДанные
//
Функция ПринятьФайл(ИмяБота, Сообщение)
	
	TelegramId = Сообщение.chat.id;
	
	Если Сообщение.Свойство("photo") Тогда
		
		file_id = Сообщение.photo[Сообщение.photo.ВГраница()].file_id; // Самое большое фото
	ИначеЕсли Сообщение.Свойство("document") Тогда
		
		file_id = Сообщение.document.file_id;
	ИначеЕсли Сообщение.Свойство("video") Тогда
		
		file_id = Сообщение.video.file_id;
	ИначеЕсли Сообщение.Свойство("voice") Тогда
		
		file_id = Сообщение.voice.file_id;
	КонецЕсли;
	
	Ресурс     = "bot" + ДанныеБота(ИмяБота).Токен + "/getFile?file_id=" + file_id;
	Соединение = Новый HTTPСоединение(ДанныеБота(ИмяБота).Сервер,443,,,,,Новый ЗащищенноеСоединениеOpenSSL());
	Запрос     = Новый HTTPЗапрос(Ресурс);
	
	Попытка
		Ответ = Соединение.Получить(Запрос);
	Исключение
		Возврат Неопределено;
	КонецПопытки;
	
	ТекстовыеДанныеОтвета = Ответ.ПолучитьТелоКакСтроку();
	
	ЧтениеJSON = Новый ЧтениеJSON();
	ЧтениеJSON.УстановитьСтроку(ТекстовыеДанныеОтвета);
	Результат = ПрочитатьJSON(ЧтениеJSON);
	ЧтениеJSON.Закрыть();
	
	Если НЕ Результат.ok ИЛИ 
		НЕ Результат.result.Свойство("file_path") ИЛИ 
		Результат.result.file_path = "" Тогда
		
		Возврат Неопределено;
	КонецЕсли;
	
	Если Сообщение.Свойство("document") Тогда
		
		ИмяФайла        = "Telegram_" + ОбщегоНазначенияКлиентСервер.РазложитьПолноеИмяФайла(Сообщение.document.file_name).ИмяБезРасширения;
		РасширениеФайла = ОбщегоНазначенияКлиентСервер.РазложитьПолноеИмяФайла(Сообщение.document.file_name).Расширение;
		РасширениеФайла = НРег(?(Лев(РасширениеФайла, 1) = ".", Сред(РасширениеФайла, 2), РасширениеФайла));
		
	ИначеЕсли Сообщение.Свойство("photo") Или
		Сообщение.Свойство("video") Или
		Сообщение.Свойство("voice") Тогда
		
		ИмяФайла        = "Telegram_" + ОбщегоНазначенияКлиентСервер.РазложитьПолноеИмяФайла(Результат.result.file_path).ИмяБезРасширения;
		РасширениеФайла = ОбщегоНазначенияКлиентСервер.РазложитьПолноеИмяФайла(Результат.result.file_path).Расширение;
		РасширениеФайла = НРег(?(Лев(РасширениеФайла, 1) = ".", Сред(РасширениеФайла, 2), РасширениеФайла));
	КонецЕсли;
	
	Ресурс     = "file/bot" + ДанныеБота(ИмяБота).Токен + "/" + Результат.result.file_path;
	Соединение = Новый HTTPСоединение(ДанныеБота(ИмяБота).Сервер,443,,,,,Новый ЗащищенноеСоединениеOpenSSL());
	Запрос     = Новый HTTPЗапрос(Ресурс);
	
	Попытка
		Ответ = Соединение.Получить(Запрос);
	Исключение
		Возврат Неопределено;
	КонецПопытки;
	
	ИнформацияОФайле = Новый Структура("ИмяФайла,РасширениеФайла,Данные");
	ИнформацияОФайле.ИмяФайла        = ИмяФайла;
	ИнформацияОФайле.РасширениеФайла = РасширениеФайла;
	ИнформацияОФайле.Данные          = Ответ.ПолучитьТелоКакДвоичныеДанные();
	
	Возврат ИнформацияОФайле;
	
КонецФункции

Процедура ВыполнитьОбработкуФайла(ИмяБота, TelegramId, ИнформацияОФайле) Экспорт
	
	Попытка
		
		MessageId = РегистрыСведений.TelegramПоследнееСообщение.ПолучитьMessageId(ИмяБота,TelegramId).MessageId;
		ОтправитьВTelegramDeleteMessage(ИмяБота,TelegramId,MessageId);
		
		ТекущийЗапрос = ПолучитьТекущийЗапрос(TelegramId,ИмяБота);
		Результат = ОбработатьФайл(ИмяБота,TelegramId,ИнформацияОФайле,ТекущийЗапрос);
		
		Если Результат Тогда
			Если ТекущийЗапрос.Команда = "СоздатьЗадачу" Тогда
				СоздатьЗадачу(ИмяБота,TelegramId,MessageId,ТекущийЗапрос,"",ИнформацияОФайле); 
			ИначеЕсли ТекущийЗапрос.Команда = "ЗавершениеЗадачиТП" Тогда
				ЗавершениеЗадачиТП(ИмяБота, TelegramId,MessageId,ТекущийЗапрос,"",ИнформацияОФайле);
			Иначе
				Если ТекущийЗапрос <> Неопределено И
					ЗначениеЗаполнено(ТекущийЗапрос.Команда) Тогда
					
					Выполнить("" + ТекущийЗапрос.Команда + "(ИмяБота, TelegramId, 0, ТекущийЗапрос, Неопределено, Неопределено, ИнформацияОФайле);");  
				КонецЕсли;
			КонецЕсли;
		КонецЕсли;
		
	Исключение
		С = ПодробноеПредставлениеОшибки(ИнформацияОбОшибке());
		
		ОтправитьВTelegramText(ИмяБота,TelegramId,0,"❗ При работе с ботом возникла ошибка, запрос был сброшен");
		НачалоРаботы(ИмяБота,TelegramId);
		
		МассивСообщенийПользователю = ПолучитьСообщенияПользователю(Истина);
		Сообщение = "";
		
		Для Каждого СообщениеПользователю Из МассивСообщенийПользователю Цикл
			
			Сообщение = Сообщение + СообщениеПользователю.Текст + Символы.ПС;
		КонецЦикла;
		
		Если Не ПустаяСтрока(Сообщение) Тогда
			
			Сообщение = Лев(Сообщение, СтрДлина(Сообщение) - 1);
			ОтправитьВTelegramText(ИмяБота,TelegramId,0, Сообщение);
			ЗаписьЖурналаРегистрации("Telegram.ВыполнитьОбработкуТекста",УровеньЖурналаРегистрации.Ошибка,,,"Сообщение пользователю:" + Символы.ПС + Сообщение);
		КонецЕсли;
	КонецПопытки;
	
КонецПроцедуры

// Обработка входящего запроса, в случае если был отправлен файл
// 
// Параметры:   
//  ИмяБота           		- Строка - Краткое внутреннее наименование бота (tec)
//  TelegramId     			- Число - Идентификатор пользователя телеграмм (также является идентификатором чата)
//  ИнформацияОФайле		- Структура - Содержит двоичные данные файла, и данные о файле
//		* ИмяФайла			- Строка - Имя файла
//		* РасширениеФайла	- Данные - Двоичные данные файла
//  ТекущийЗапрос			- Структура - Содержит сохраненные данные, полученные в результате предыдущих запросов пользователя в рамках одной команды
//		* Команда  			- Строка - Наименование команды
//		* Стадия			- Число - Стадия запроса
//		* ИмяБота			- Строка - Имя бота
//		* Данные			- Структура,Строка - Данные, полученные от пользователя (произвольный набор данных)
//
// Возвращаемое значение: 
//  Булево              	- Истина, в случае если файл можно принимать
//							- Ложь, если файл принимать нельзя (не зарегистрирован пользователь или несуществующий запрос)
// 
Функция ОбработатьФайл(ИмяБота, TelegramId, ИнформацияОФайле, ТекущийЗапрос) Экспорт
	
	Зарегистрирован = СотрудникЗарегистрированВTelegram(TelegramId);
	
	Если Не Зарегистрирован Тогда
		
		Возврат Ложь;
	КонецЕсли;
	
	ИмяФайла        = ИнформацияОФайле.ИмяФайла;
	РасширениеФайла = ИнформацияОФайле.РасширениеФайла;
	Данные          = ИнформацияОФайле.Данные;
	
	Если ТекущийЗапрос.Данные.Свойство("ДанныеЗадачиТехПоддержки") И ТекущийЗапрос.Данные.ДанныеЗадачиТехПоддержки.Свойство("Задача") Тогда
		
		IDФайла = ФайлыСервер.Записать(ТекущийЗапрос.Данные.ДанныеЗадачиТехПоддержки.Задача,Данные,ИмяФайла,РасширениеФайла,0,Ложь,ПараметрыСеанса.Сотрудник);
	ИначеЕсли ТекущийЗапрос.Данные.Свойство("Задача") Тогда	 
		
		Если ЗначениеЗаполнено(ТекущийЗапрос.Данные.Задача) Тогда
			
			IDФайла = ФайлыСервер.Записать(ТекущийЗапрос.Данные.Задача,Данные,ИмяФайла,РасширениеФайла,0,Ложь,ПараметрыСеанса.Сотрудник); 
		Иначе
			
			IDФайла = Новый УникальныйИдентификатор("00000000-0000-0000-0000-000000000000");
		КонецЕсли;
	Иначе
		IDФайла = ФайлыСервер.Записать(ПараметрыСеанса.Сотрудник,Данные,ИмяФайла,РасширениеФайла,0,Ложь,ПараметрыСеанса.Сотрудник);
	КонецЕсли;                    
	
	Если IDФайла = Неопределено Тогда 		
		
		СтрокаИнтернетОтвета = "❗ Не удалось загрузить файл";
	Иначе
		СтрокаИнтернетОтвета = "✌ Файл " + ИмяФайла + "." + РасширениеФайла + " успешно отправлен"; 
		ИнформацияОФайле.Вставить("IDФайла",IDФайла);
	КонецЕсли;                    
	
	ОтправитьВTelegramText(ИмяБота,TelegramId,0,СтрокаИнтернетОтвета);
	
	Возврат Истина;
	
КонецФункции

Функция ЭтоФайл(Данные) Экспорт
	
	Если НЕ ТипЗнч(Данные) = Тип("Структура") ИЛИ
		НЕ Данные.Свойство("ИмяФайла") ИЛИ
		НЕ Данные.Свойство("РасширениеФайла") ИЛИ
		НЕ Данные.Свойство("Данные") Тогда
		
		Возврат Ложь;
	КонецЕсли;
	
	Возврат Истина;
	
КонецФункции

#КонецОбласти

#Область РегистрацияИдентификацияПользователя    

Процедура Зарегистрироваться(ИмяБота, TelegramId, MessageId, ТекущийЗапрос = Неопределено, Сообщение = Неопределено)
	
	СтрокаИнтернетОтвета = "";
	Reply_markup = "";
	РедактируемоеСообщение = 0;
	
	КомандаЗавершена = Ложь;
	
	Данные = Новый Структура("phone, name, agreement, resultregistation, conf_code");
	
	Если НЕ ТекущийЗапрос = Неопределено Тогда
		ЗаполнитьЗначенияСвойств(Данные, ТекущийЗапрос.Данные);
	КонецЕсли;
	
	Если ТекущийЗапрос = Неопределено Тогда
		
		ДобавитьВТекущийЗапрос(ИмяБота, TelegramId, "Зарегистрироваться", 1, Данные);
		СтрокаИнтернетОтвета = "Как к Вам можно обращаться?";
		РедактируемоеСообщение = MessageId;
	ИначеЕсли ТекущийЗапрос.Стадия = 1 Тогда
		Данные.name = Сообщение.text;
		
		ДобавитьВТекущийЗапрос(ИмяБота, TelegramId, "Зарегистрироваться", 2, Данные);
		СтрокаИнтернетОтвета = "Отправьте свой номер телефона";
		
	ИначеЕсли ТекущийЗапрос.Стадия = 2 Тогда
		
		Если Сообщение.Свойство("entities") И Сообщение.entities[0].type = "phone_number" Тогда
			
			Данные.phone = Сообщение.text;
			
			ДобавитьВТекущийЗапрос(ИмяБота, TelegramId, "Зарегистрироваться", 3, Данные);
			
			ПринятьРешениеОРегистрацииПользователяВСистеме(ИмяБота, TelegramId, MessageId, Данные);
			
			ТекущийЗапрос.Стадия = 3;
			ТекущийЗапрос.Данные = Данные;
			Зарегистрироваться(ИмяБота, TelegramId, 0, ТекущийЗапрос);
			
		Иначе // телега не распознала номер телефона
			СтрокаИнтернетОтвета = "Номер телефона введен некорректно! Повторите ввод";
		КонецЕсли;
		
	ИначеЕсли ТекущийЗапрос.Стадия = 3 Тогда
		
		ОтправитьКодПодтверждения(Данные);
		
		Если ОбщийСерверПовтИсп.ЭтоНеРабочаяБаза() Тогда
			
			СтрокаИнтернетОтвета = "Введите код подтверждения ("+Данные.conf_code+")";
		Иначе
			
			СтрокаИнтернетОтвета = "Введите код подтверждения";
		КонецЕсли;
		
		ДобавитьВТекущийЗапрос(ИмяБота, TelegramId, "Зарегистрироваться", 4, Данные, 60*10);
		
		РедактируемоеСообщение = MessageId;
		
	ИначеЕсли ТекущийЗапрос.Стадия = 4 Тогда
		
		ВведенныйКодСовпадает = Ложь;
		ПроверитьВведенныйКодПодтверждения(Сообщение.text, ВведенныйКодСовпадает, Данные.conf_code);
		Если ВведенныйКодСовпадает Тогда
			ТекущийЗапрос.Данные = Данные;
			ТекущийЗапрос.Стадия = 4;
			
			//СтрокаИнтернетОтвета = СериализоватьВJSON(ТекущийЗапрос.Данные);
			
			НачатьТранзакцию();
			Попытка
				Справочники.Пользователи.СоздатьПользователя(
				Новый Структура("ПолнНаименование, TelegramId, НомерТелефона",
				Данные.name,
				TelegramId,
				Данные.phone));
				ЗафиксироватьТранзакцию();
			Исключение
				Если ТранзакцияАктивна() Тогда
					ОтменитьТранзакцию();
				КонецЕсли;
				
				ЗаписьЖурналаРегистрации("ПроцедураРегистрации", УровеньЖурналаРегистрации.Ошибка,,, ОписаниеОшибки());
			КонецПопытки;
			
			КомандаЗавершена = Истина;
			
		Иначе
			СтрокаИнтернетОтвета = "Код подтверждения неверный! Повторите ввод.";
		КонецЕсли;
		
	КонецЕсли;
	
	Если НЕ ПустаяСтрока(СтрокаИнтернетОтвета) тогда
		ОтправитьВTelegramText(ИмяБота, TelegramId, РедактируемоеСообщение, СтрокаИнтернетОтвета, Reply_markup);
	КонецЕсли;
	
	Если КомандаЗавершена Тогда
		
		НачалоРаботы(ИмяБота, TelegramId);
	КонецЕсли;
	
	
КонецПроцедуры

