
Процедура СоздатьЗадачу(ИмяБота, TelegramId, MessageId, ТекущийЗапрос, Сообщение, ИнформацияОФайле = Неопределено, Ошибка = Ложь)
	
	// Этапы создания задачи:
	// 1. Выберите вариант создания (Краткий, Подробный, Бэклог, ТехПоддержка)
	// 2. Укажите цель задачи
	// 3. + Подробное описание задачи (вариант "Подробный", в "Кратком" и "Бэклоге"- не заполнено)
	// 4. - Выберите организацию (Выбор вариантов)  - пропускаем
	// 5. + Выберите исполнителя (Выбор вариантов) (вариант "Подробный" и "ТехПоддержка", в "Кратком" = Текущему пользователю)
	// 6. + Выберите контролирующее лицо (вариант "Подробный", в "Кратком" - не заполнено, в "ТехПоддержке" - группа для оповещения)
	// 7. Приступить к задаче немедленно (Выбор из вариантов "Да|Нет") 
	// 8. Выберите задача периодическая или нет (Выбор из вариантов "Да|Нет")
	// 8. Укажите дату начала задачи (выбор даты, если "Немедленно","Периодичная","Бэклог" или "ТехПоддержка" - начало тек.минуты)
	// 9. + Укажите срок исполнения задачи ("Подробный" - выбор даты, "Периодичная" - ввод продолжительности задачи (мин), в "Кратком" +15 минут от даты начала, "Бэклог" или "ТехПоддержка" +5 минут от даты начала)
	// 10. + Прикрепите файлы (или Пропустить) (вариант "Подробный" и "ТехПоддержка")
	
	СтрокаИнтернетОтвета = "⭐ Создать задачу
	|➡️ На кого будем ставить задачу:
	|<b>На себя (Кратко)</b> - краткое описание задачи.
	|<b>На себя (Подробно)</b> - подробное описание задачи с выбором контролирущего сотрудника на себя.
	|<b>На себя (Периодично)</b> - после остановки задачи не нужно завершать задачу и возможно настроить время напоминания о задаче.
	|<b>На сотрудника</b> -  задача на группу или сотрудника с выбором контролирущего сотрудника";
	СтрокаИнтернетОтвета2 = "";
	reply_markup = "";
	ОтправитьКалендарь = Ложь;
	ОтправитьНачалоРаботы = Ложь;
	Сотрудник = ПолучитьСотрудникаПоTelegramId(TelegramId); 
	ВыполнитьСтартЗадачи = Ложь;
	
	Данные = Новый Структура("Тип,Цель,ЦельПодробно,Исполнитель,Группа,ДопКонтроль,Немедленно,Дата,СрокИсполнения,Задача,Файлы, Организация");
	
	Если Не ТекущийЗапрос = Неопределено Тогда
		
		ЗаполнитьЗначенияСвойств(Данные,ТекущийЗапрос.Данные); 
		
		Если ЗначениеЗаполнено(Данные.Тип) Тогда
			
			Выполнить("СоздатьЗадачу"+ТекущийЗапрос.Данные.Тип+"(ИмяБота,TelegramId,MessageId,ТекущийЗапрос,Сообщение,ИнформацияОФайле,Ошибка)");
			Возврат;
		КонецЕсли;
	КонецЕсли;
	
	Если ТекущийЗапрос = Неопределено Тогда
		
		ТекущийЗапрос = Новый Структура("Команда,Стадия,Данные","СоздатьЗадачу",0,Данные);
	КонецЕсли;     
	
	Если ТекущийЗапрос.Стадия = 0 Тогда			// выбор "Вариант создания"
		#Область ВыборВариантаСозданияЗадачи
		
		Данные.Тип = Неопределено;
		Данные.Цель = Неопределено;
		Данные.ЦельПодробно = Неопределено;
		Данные.Исполнитель = Неопределено;
		Данные.Группа = Неопределено;
		Данные.ДопКонтроль = Неопределено;
		Данные.Немедленно = Неопределено;
		Данные.Дата = Неопределено;
		Данные.СрокИсполнения = Неопределено;
		Данные.Задача = Неопределено;
		Данные.Файлы = Неопределено;
		
		// Укажем "Вариант создания"
		СтрокаИнтернетОтвета2 = "➡ Выберите вариант создания:";
		
		IK = СоздатьInlineKeyboard();
		
		IK.ЗаписатьНачалоМассива();                  
		ДобавитьInlineКнопку(IK, "На себя (Кратко)", "НаСебяКратко");
		IK.ЗаписатьКонецМассива();                            
		
		IK.ЗаписатьНачалоМассива();                           	
		ДобавитьInlineКнопку(IK, "На себя (Подробно)", "НаСебяПодробно");
		ДобавитьInlineКнопку(IK, "На себя (Периодично)", "НаСебяПериодично");
		IK.ЗаписатьКонецМассива();
		
		IK.ЗаписатьНачалоМассива();                  
		ДобавитьInlineКнопку(IK, "На сотрудника", "НаСотрудника");
		IK.ЗаписатьКонецМассива();
		
		reply_markup = ДобавитьInlineКнопкуОтменить(IK);  
		#КонецОбласти
		ДобавитьВТекущийЗапрос(ИмяБота,TelegramId,"СоздатьЗадачу",1,Данные);
	ИначеЕсли ТекущийЗапрос.Стадия = 1 Тогда	// выбрали "Вариант создания"
		
		ТекущийЗапрос.Данные.Тип = Сообщение;  
		СоздатьЗадачу(ИмяБота, TelegramId, MessageId, ТекущийЗапрос, "");
		Возврат;
	КонецЕсли;
	
	Если ЗначениеЗаполнено(Данные.Организация) Тогда
		СтрокаИнтернетОтвета = СтрокаИнтернетОтвета + Символы.ПС + "<b>✔ Организация:</b> " + Данные.Организация;
	КонецЕсли;
	
	Если ЗначениеЗаполнено(Данные.Цель) Тогда
		
		СтрокаИнтернетОтвета = СтрокаИнтернетОтвета + Символы.ПС + "<b>✔ Цель:</b> " + Данные.Цель;		
	КонецЕсли;
	
	Если ЗначениеЗаполнено(Данные.ЦельПодробно) Тогда
		
		СтрокаИнтернетОтвета = СтрокаИнтернетОтвета + Символы.ПС + "<b>✔ Цель (подробно):</b> " + Данные.ЦельПодробно;		
	КонецЕсли;
	
	Если ЗначениеЗаполнено(Данные.Исполнитель) Тогда
		
		СтрокаИнтернетОтвета = СтрокаИнтернетОтвета + Символы.ПС + "<b>✔ Исполнитель:</b> " + Данные.Исполнитель;		
	КонецЕсли;
	
	Если ЗначениеЗаполнено(Данные.Группа) Тогда
		
		СтрокаИнтернетОтвета = СтрокаИнтернетОтвета + Символы.ПС + "<b>✔ Группа:</b> " + Данные.Группа;		
	КонецЕсли;
	
	Если ЗначениеЗаполнено(Данные.ДопКонтроль) Тогда
		
		СтрокаИнтернетОтвета = СтрокаИнтернетОтвета + Символы.ПС + "<b>✔ На контроле:</b> " + Данные.ДопКонтроль;
	КонецЕсли;
	
	Если ЗначениеЗаполнено(Данные.Дата) Тогда
		
		СтрокаИнтернетОтвета = СтрокаИнтернетОтвета + Символы.ПС + "<b>✔ Дата:</b> " + Данные.Дата;		
	КонецЕсли;                                                                                      
	
	Если Данные.Свойство("Файлы") 
		И Данные.Файлы <> Неопределено 
		И Данные.Файлы.Количество() Тогда
		
		СтрокаИнтернетОтвета = СтрокаИнтернетОтвета + Символы.ПС + "<b>✔ Прикрепленные файлы:</b> " + Данные.Файлы.Количество();		
	КонецЕсли;
	
	СтрокаИнтернетОтвета = СтрокаИнтернетОтвета + Символы.ПС + СтрокаИнтернетОтвета2;	
	
	ОтправитьВTelegramDeleteMessage(ИмяБота,TelegramId,MessageId);	
	ОтправитьВTelegramText(ИмяБота, TelegramId, 0, СтрокаИнтернетОтвета, reply_markup, Истина);		
	
	Если ОтправитьНачалоРаботы Тогда
		
		НачалоРаботы(ИмяБота,TelegramId);
	КонецЕсли;  
	
	Если ВыполнитьСтартЗадачи Тогда
		
		ОбщийСервер.СтартЗадачи(Данные.Задача,,,Истина,Истина);     
	КонецЕсли;
	
КонецПроцедуры

Процедура СоздатьЗадачуНаСебяКратко(ИмяБота, TelegramId, MessageId, ТекущийЗапрос, Сообщение, ИнформацияОФайле = Неопределено, Ошибка = Ложь)
	
	СтрокаИнтернетОтвета = "⭐ Создать задачу";
	СтрокаИнтернетОтвета2 = "";
	reply_markup = "";
	ОтправитьКалендарь = Ложь;
	ОтправитьНачалоРаботы = Ложь;
	Сотрудник = ПолучитьСотрудникаПоTelegramId(TelegramId); 
	ВыполнитьСтартЗадачи = Ложь;
	
	Данные = Новый Структура("Тип,Цель,ЦельПодробно,Исполнитель,Группа,ДопКонтроль,Немедленно,Дата,СрокИсполнения,Задача,Файлы, Организация");
	
	Если Не ТекущийЗапрос = Неопределено Тогда
		
		ЗаполнитьЗначенияСвойств(Данные,ТекущийЗапрос.Данные);
	КонецЕсли;
	
	Если ТекущийЗапрос = Неопределено Тогда
		
		ТекущийЗапрос = Новый Структура("Команда,Стадия,Данные","СоздатьЗадачу",0,Данные);
	КонецЕсли;     
	
	Если ТекущийЗапрос.Стадия = 1 Тогда  
		#Область ВводЦелиКратко
		Данные.Цель = Неопределено;
		Данные.ЦельПодробно = Неопределено;
		Данные.Исполнитель = ПараметрыСеанса.Сотрудник;
		Данные.Группа = Неопределено;
		Данные.ДопКонтроль = Неопределено;
		Данные.Немедленно = Неопределено;
		Данные.Дата = Неопределено;
		Данные.СрокИсполнения = Неопределено;
		Данные.Задача = Неопределено;
		Данные.Файлы = Неопределено;
		
		ДобавитьВТекущийЗапрос(ИмяБота,TelegramId,"СоздатьЗадачу",2,Данные);
		
		// Укажем "Цель (кратко)"
		СтрокаИнтернетОтвета2 = "➡ Укажите цель (кратко): ";
		
		reply_markup = ДобавитьОсновныеInlineКнопки();	  
		#КонецОбласти
	ИначеЕсли ТекущийЗапрос.Стадия = 2 Тогда
		#Область ВыборПлательщика
		Данные.Цель = Сообщение;
		Данные.Организация = Неопределено;	
		Данные.Группа = Неопределено;
		Данные.ДопКонтроль = Неопределено;
		Данные.Немедленно = Неопределено;
		Данные.Дата = Неопределено;
		Данные.СрокИсполнения = Неопределено;
		Данные.Задача = Неопределено;
		Данные.Файлы = Неопределено;
		
		// Укажем "Организацию"
		СтрокаИнтернетОтвета2 = "➡ Выберите плательщика:";
		
		Клиенты = Справочники.Клиенты.ПолучитьСписокДоступныхПользователюКлиентов(ПараметрыСеанса.ТекущееПространство, ПараметрыСеанса.Сотрудник);
		
		Если Клиенты.Количество() = 1 Тогда
			Данные.Организация = Клиенты[0].Ссылка;
			ТекущийЗапрос.Стадия = 3;
			ТекущийЗапрос.Данные = Данные;
			СоздатьЗадачу(ИмяБота, TelegramId, MessageId, ТекущийЗапрос, Сообщение, ИнформацияОФайле, Ошибка);
			Возврат;
		КонецЕсли;
		
		Если Клиенты.Количество() = 0 Тогда 
			
			// Добавление клиента      
			ПереходНаКоманду = Новый Структура("Команда,ИмяБота,TelegramId, MessageId, ТекущийЗапрос, Сообщение","СоздатьЗадачу",ИмяБота,TelegramId, MessageId, ТекущийЗапрос, Сообщение);
			ПлательщикиДобавить(ИмяБота, TelegramId, MessageId, Неопределено, "",ПереходНаКоманду);
			Возврат;
		КонецЕсли;       
		
		IK = СоздатьInlineKeyboard();
		
		Для Каждого Клиент ИЗ Клиенты Цикл
			
			IK.ЗаписатьНачалоМассива();
			ДобавитьInlineКнопку(IK, Строка(Клиент), Строка(Клиент.УникальныйИдентификатор()));
			IK.ЗаписатьКонецМассива();			
		КонецЦикла;
		
		reply_markup = ДобавитьОсновныеInlineКнопки(IK);
		
		ДобавитьВТекущийЗапрос(ИмяБота,TelegramId,"СоздатьЗадачу",3,Данные);		
		#КонецОбласти  
	ИначеЕсли ТекущийЗапрос.Стадия = 3 Тогда
		#Область ВыборНачалаЗадачи
		
		Если Данные.Организация = Неопределено Тогда
			Данные.Организация = Справочники.Клиенты.ПолучитьСсылку(Новый УникальныйИдентификатор(Сообщение));
		КонецЕсли;
		
		СтрокаИнтернетОтвета2 = "➡ Приступить к выполнению задачи?
		|Если выбираем Нет, то выбираем дату и время начала выполнения задачи (уведомление к выполнению задачи придет за 15 минут).";
		
		IK = СоздатьInlineKeyboard();  		
		
		IK.ЗаписатьНачалоМассива();
		ДобавитьInlineКнопку(IK, "Да", 1);
		ДобавитьInlineКнопку(IK, "Нет", 0);
		IK.ЗаписатьКонецМассива();
		
		reply_markup = ДобавитьОсновныеInlineКнопки(IK);    
		ДобавитьВТекущийЗапрос(ИмяБота,TelegramId,"СоздатьЗадачу",31,Данные);
		#КонецОбласти           
	ИначеЕсли ТекущийЗапрос.Стадия = 31 Тогда
		#Область ЗапускЗадачиИлиВыборДатыНачала
		Данные.Немедленно = ?(Сообщение = "1",Истина,Ложь);  
		
		Если Данные.Немедленно Тогда
			
			Данные.Дата = НачалоМинуты(ТекущаяДата());                                          
			ТекущийЗапрос.Стадия = 5;
			ТекущийЗапрос.Данные = Данные;
			
			СоздатьЗадачу(ИмяБота, TelegramId, MessageId, ТекущийЗапрос, Сообщение, ИнформацияОФайле, Ошибка);  
			Возврат;
		Иначе
			
			День3 = ДеньНедели(ТекущаяДата()+(86400*3));
			
			Смещение = 0;
			Если День3 = 6 Тогда
				
				Смещение = -1;
			ИначеЕсли День3 = 7 Тогда
				
				Смещение = 1;
			КонецЕсли;       
			
			Смещение3дн = 86400*(3+Смещение);
			
			IK = СоздатьInlineKeyboard();  		
			
			IK.ЗаписатьНачалоМассива();
			ДобавитьInlineКнопку(IK, "\ud83d\udcc5 Календарь", "manual");
			IK.ЗаписатьКонецМассива();
			
			IK.ЗаписатьНачалоМассива();       
			Дата7 = ТекущаяДата() + (86400*7);
			ДобавитьInlineКнопку(IK, "Через неделю ("+ День(Дата7)+"."+Месяц(Дата7)+")", Строка(86400*7));  
			
			ДатаМес = ДобавитьМесяц(ТекущаяДата(),1);
			ДобавитьInlineКнопку(IK, "Через месяц (" + День(ДатаМес)+"."+Месяц(ДатаМес)+")", Строка(ДатаМес-ТекущаяДата()));
			IK.ЗаписатьКонецМассива();   
			
			IK.ЗаписатьНачалоМассива();
			ДобавитьInlineКнопку(IK, "Завтра", 86400); 
			
			День3дн = ТекущаяДата()+Смещение3дн;
			ДеньСтрокой = Формат(День3дн,"ДФ=дддд");		
			ДеньСтрокой = ВРег(Лев(ДеньСтрокой,1)) + Прав(ДеньСтрокой,СтрДлина(ДеньСтрокой)-1);
			
			ДобавитьInlineКнопку(IK, ДеньСтрокой + " ("+День(День3Дн)+"."+Месяц(День3Дн)+")", Строка(Смещение3дн));
			IK.ЗаписатьКонецМассива();
			
			IK.ЗаписатьНачалоМассива();
			ДобавитьInlineКнопку(IK, "\ud83d\udca5 Сегодня", 0);
			IK.ЗаписатьКонецМассива();
			
			СтрокаИнтернетОтвета2 = "➡ Выберите дату начала:";      
			reply_markup = ДобавитьОсновныеInlineКнопки(IK);    
			
			ДобавитьВТекущийЗапрос(ИмяБота,TelegramId,"СоздатьЗадачу",4,Данные);
			
		КонецЕсли;
		#КонецОбласти	
	ИначеЕсли ТекущийЗапрос.Стадия = 4 Тогда
		#Область ВыборДатыНачала
		
		Если Сообщение = "manual" Тогда
			
			СообщениеКалендаря = Неопределено;
			ОтправитьКалендарь = Истина;
			ДобавитьВТекущийЗапрос(ИмяБота,TelegramId,"СоздатьЗадачу",5,Данные);	 
		Иначе
			
			Данные.Дата = ТекущаяДата() + ОбщийСервер.СтрокаВЧисло(Сообщение);
			
			ТекущийЗапрос.Стадия = 5; 
			ТекущийЗапрос.Данные = Данные;
			СоздатьЗадачу(ИмяБота, TelegramId, MessageId, ТекущийЗапрос, "", ИнформацияОФайле, Ошибка);
			Возврат;			
		КонецЕсли;
		
		#КонецОбласти      
	ИначеЕсли ТекущийЗапрос.Стадия = 5 Тогда
		#Область ЗапускЗадачи
		
		Если Сообщение = "0" Тогда
			
			СообщениеКалендаря = Неопределено;
			ОтправитьКалендарь = Истина;
			ДобавитьВТекущийЗапрос(ИмяБота,TelegramId,"СоздатьЗадачу",5,Данные);
			
		Иначе
			
			Если Данные.Дата = Неопределено Тогда
				
				
				Данные.Дата = Дата(1,1,1) + Число(Сообщение);
			КонецЕсли;
			
			Данные.СрокИсполнения = Данные.Дата + (5*60);
			Попытка
				НачатьТранзакцию(РежимУправленияБлокировкойДанных.Управляемый);
				
				Док = Документы.Задача.СоздатьДокумент();
				Док.Заполнить(Неопределено);
				
				Док.Пространство	= ПараметрыСеанса.ТекущееПространство;
				Док.Автор			= ПараметрыСеанса.Сотрудник;
				Док.Цель			= Данные.Цель;
				Док.ЦельПодробно	= Данные.ЦельПодробно;
				Док.Организация		= Данные.Организация;
				Док.Исполнитель		= Данные.Исполнитель;
				Док.Группа			= Данные.Группа;
				Док.Дата			= Данные.Дата;
				Док.СрокИсполнения	= Данные.СрокИсполнения;
				Док.ТипЗадачи	= Перечисления.ТипыЗадач.Обычная;
				
				Док.Записать(РежимЗаписиДокумента.Запись);
				
				Данные.Задача = Док.Ссылка;
				ЗафиксироватьТранзакцию();
				
			Исключение
				С = ОписаниеОшибки();
				ОтменитьТранзакцию();
			КонецПопытки;   
			
			Если Данные.Немедленно Тогда
				
				ВыполнитьСтартЗадачи = Истина;
			Иначе
				ОтправитьНачалоРаботы = Истина;      
			КонецЕсли;   
			
			СтрокаИнтернетОтвета2 = "✌ Задача успешно создана";
			
			УдалитьТекущийЗапрос(ИмяБота, TelegramId);
		КонецЕсли;
		#КонецОбласти
	КонецЕсли;  
	
	Если ЗначениеЗаполнено(Данные.Тип) Тогда
		
		СтрокаИнтернетОтвета = СтрокаИнтернетОтвета + Символы.ПС + "<b>✔ Тип задачи:</b> " + СтроковыеФункцииКлиентСервер.ДобавитьПробелыМеждуСловСВерхнимРегистром(Данные.Тип, Истина);		
	КонецЕсли;     	
	
	Если ЗначениеЗаполнено(Данные.Цель) Тогда
		
		СтрокаИнтернетОтвета = СтрокаИнтернетОтвета + Символы.ПС + "<b>✔ Цель:</b> " + Данные.Цель;		
	КонецЕсли;     
	
	Если ЗначениеЗаполнено(Данные.Организация) Тогда
		СтрокаИнтернетОтвета = СтрокаИнтернетОтвета + Символы.ПС + "<b>✔ Организация:</b> " + Данные.Организация;
	КонецЕсли;
	
	Если ЗначениеЗаполнено(Данные.Исполнитель) Тогда
		
		СтрокаИнтернетОтвета = СтрокаИнтернетОтвета + Символы.ПС + "<b>✔ Исполнитель:</b> " + Данные.Исполнитель;		
	КонецЕсли;
	
	Если ЗначениеЗаполнено(Данные.Дата) Тогда
		
		СтрокаИнтернетОтвета = СтрокаИнтернетОтвета + Символы.ПС + "<b>✔ Дата:</b> " + Данные.Дата;		
	КонецЕсли;                                                                                      
	
	СтрокаИнтернетОтвета = СтрокаИнтернетОтвета + Символы.ПС + СтрокаИнтернетОтвета2;	
	
	ОтправитьВTelegramDeleteMessage(ИмяБота,TelegramId,MessageId);
	
	Если ОтправитьКалендарь Тогда
		
		ОткрытьВремя(ИмяБота, TelegramId, 0, СообщениеКалендаря, СтрокаИнтернетОтвета);
	Иначе
		ОтправитьВTelegramText(ИмяБота, TelegramId, 0, СтрокаИнтернетОтвета, reply_markup, Истина);		
	КонецЕсли;
	
	Если ОтправитьНачалоРаботы Тогда
		
		НачалоРаботы(ИмяБота,TelegramId);
	КонецЕсли;  
	
	Если ВыполнитьСтартЗадачи Тогда
		
		ОбщийСервер.СтартЗадачи(Данные.Задача,,,Истина,Истина);     
	КонецЕсли;
	
КонецПроцедуры


Процедура ОтчетностьМеню(ИмяБота, TelegramId, MessageId, ТекущийЗапрос, Сообщение)
	
	СтрокаИнтернетОтвета = "Выберите действие:"
	+Символы.ПС + "⏰ <b>Тайминг дня</b> - показывает распределение времени сотрудников на выполнение поставленных задач в рамках выбранного периода"
	+Символы.ПС + "<b>Анализ потраченного времени</b> - показывает количество задач, по которым уже проводилась работа, суммарно затраченное время на их реализацию, расчетную стоимость реализации в рамка выбранного периода"
	+Символы.ПС + "&#127918; <b>На контроле</b> - возможность просмотра online задач и незавершенных задач";
	
	СтрокаJSON = СоздатьInlineKeyboard();
	
	СтрокаJSON.ЗаписатьНачалоМассива();
	ДобавитьInlineКнопку(СтрокаJSON, "⏰ Тайминг дня", "daytiming");
	СтрокаJSON.ЗаписатьКонецМассива();
	
	СтрокаJSON.ЗаписатьНачалоМассива();
	ДобавитьInlineКнопку(СтрокаJSON, "Анализ потраченного времени", "elapsedtime");
	СтрокаJSON.ЗаписатьКонецМассива();
	
	СтрокаJSON.ЗаписатьНачалоМассива();
	ДобавитьInlineКнопку(СтрокаJSON, "\uD83C\uDFAE На контроле", "grouptasks");
	СтрокаJSON.ЗаписатьКонецМассива();
	
	reply_markup = ДобавитьInlineКнопкуОтменить(СтрокаJSON);
	
	ОтправитьВTelegramText(ИмяБота, TelegramId, MessageId, СтрокаИнтернетОтвета, reply_markup, Истина);
	
КонецПроцедуры

Процедура ОтчетПотраченноеВремя(ИмяБота, TelegramId, MessageId, ТекущийЗапрос, Сообщение)
	Попытка
		СТрокаИнтернетОтвета = "";
		reply_markup = "";
		ОтправитьНачалоРаботы = Ложь;
		ОтправитьКалендарь = Ложь;
		
		Данные = Новый Структура("НачалоПериода, ОкончаниеПериода, Пользователи, ГруппаАдресации");
		
		Если Не ТекущийЗапрос = Неопределено Тогда		
			ЗаполнитьЗначенияСвойств(Данные,ТекущийЗапрос.Данные);
		КонецЕсли;
		
		Если ТекущийЗапрос = Неопределено Тогда
			ДобавитьВТекущийЗапрос(ИмяБота, TelegramId, "ОтчетПотраченноеВремя", 1, Данные);
			
			АдминистрируемыеПространства = ПраваИНастройки.ДоступныеПространстваПользователя(ПараметрыСеанса.Сотрудник, Перечисления.РолиПользователей.Администратор);
			
			ЭтоАдминистратор = НЕ АдминистрируемыеПространства.Найти(ПараметрыСеанса.ТекущееПространство) = Неопределено;
			РуководительГруппАдресации = Справочники.ГруппыАдресации.ПолучитьДоступныеГруппыАдресацииРуководителя(ПараметрыСеанса.ТекущееПространство,ПараметрыСеанса.Сотрудник);
			
			Если ЭтоАдминистратор Тогда
				
				Пользователи = ПраваИНастройки.ПолучитьПользователейПространства(ПараметрыСеанса.ТекущееПространство);
				
				ГруппыАдресации = Справочники.ГруппыАдресации.ПолучитьГруппыАдресацииПространства(ПараметрыСеанса.ТекущееПространство);
				
				ЗаписьJSON = СоздатьInlineKeyboard();
				Для Каждого Группа Из ГруппыАдресации Цикл
					ЗаписьJSON.ЗаписатьНачалоМассива();
					ДобавитьInlineКнопку(ЗаписьJSON, Строка(Группа)+"(группа)", "group:" + Строка(Группа.УникальныйИдентификатор()));
					ЗаписьJSON.ЗаписатьКонецМассива();
				КонецЦикла;
				
				Для Каждого Пользователь Из Пользователи Цикл 
					ЗаписьJSON.ЗаписатьНачалоМассива();
					ДобавитьInlineКнопку(ЗаписьJSON, Строка(Пользователь), "employee:" + Строка(Пользователь.УникальныйИдентификатор()));
					ЗаписьJSON.ЗаписатьКонецМассива();
				КонецЦикла;
				
				reply_markup = ДобавитьInlineКнопкуОтменить(ЗаписьJSON);			
			ИначеЕсли РуководительГруппАдресации.Количество() Тогда
				
				ПользователиВСписок = Новый Массив;
				ЗаписьJSON = СоздатьInlineKeyboard();
				Для Каждого Группа Из РуководительГруппАдресации Цикл
					ЗаписьJSON.ЗаписатьНачалоМассива();
					ДобавитьInlineКнопку(ЗаписьJSON, Строка(Группа)+"(группа)", "group:" + Строка(Группа.УникальныйИдентификатор()));
					ЗаписьJSON.ЗаписатьКонецМассива();
					
					ДоступныеПользователи = Справочники.ГруппыАдресации.ПолучитьУчастниковГруппыАдресации(ПараметрыСеанса.ТекущееПространство, Группа);
					Для Каждого текПользователь Из ДоступныеПользователи Цикл
						
						Если ПользователиВСписок.Найти(текПользователь) = Неопределено Тогда
							
							ПользователиВСписок.Добавить(текПользователь);
						КонецЕсли;
					КонецЦикла;
				КонецЦикла;  
				
				Для Каждого Пользователь Из ПользователиВСписок Цикл
					
					ЗаписьJSON.ЗаписатьНачалоМассива();
					ДобавитьInlineКнопку(ЗаписьJSON, Строка(Пользователь), "employee:" + Строка(Пользователь.УникальныйИдентификатор()));
					ЗаписьJSON.ЗаписатьКонецМассива();
				КонецЦикла;    
				reply_markup = ДобавитьInlineКнопкуОтменить(ЗаписьJSON);
			Иначе
				
				ТекущийЗапрос = Новый Структура("Стадия, Данные, Команда", 1, Данные, "ОтчетПотраченноеВремя");
				ОтчетПотраченноеВремя(ИмяБота, TelegramId, MessageId, ТекущийЗапрос, "employee:" + Строка(ПараметрыСеанса.Сотрудник.УникальныйИдентификатор()));
				Возврат;
			КонецЕсли;
			
			СтрокаИнтернетОтвета  = "➡ Выберите сотрудника или группу:";
		ИначеЕсли ТекущийЗапрос.Стадия = 1 Тогда
			Если Найти(Сообщение, "group:")>0 Тогда
				
				guidГруппаАдресации = Сред(Сообщение, найти(Сообщение, ":")+1);
				Данные.ГруппаАдресации = guidГруппаАдресации;
				
			ИначеЕсли Найти(Сообщение, "employee:")>0 Тогда
				guidПользователь = Сред(Сообщение, найти(Сообщение, ":")+1);
				Данные.Пользователи = guidПользователь;
			КонецЕсли;
			
			ДобавитьВТекущийЗапрос(ИмяБота, TelegramId, "ОтчетПотраченноеВремя", 2, Данные);
			
			// Формируем выбор периодов
			ЗаписьJSON = СоздатьInlineKeyboard();
			
			ЗаписьJSON.ЗаписатьНачалоМассива();
			ДобавитьInlineКнопку(ЗаписьJSON, "С начала текущего месяца", "beginmonth");
			ЗаписьJSON.ЗаписатьКонецМассива();
			
			ЗаписьJSON.ЗаписатьНачалоМассива();
			ДобавитьInlineКнопку(ЗаписьJSON, "Прошлая неделя", "lastweek");
			ЗаписьJSON.ЗаписатьКонецМассива();
			
			ЗаписьJSON.ЗаписатьНачалоМассива();
			ДобавитьInlineКнопку(ЗаписьJSON, "Текущая неделя", "thisweek");
			ЗаписьJSON.ЗаписатьКонецМассива();
			
			ЗаписьJSON.ЗаписатьНачалоМассива();
			ДобавитьInlineКнопку(ЗаписьJSON, "Произвольный период", "arbitrary");
			ЗаписьJSON.ЗаписатьКонецМассива();
			
			reply_markup = ЗавершитьInlineKeyboard(ЗаписьJSON);
			
			СтрокаИнтернетОтвета = "Выберите период отчета";
			
		ИначеЕсли ТекущийЗапрос.Стадия = 2 Тогда
			
			Если Сообщение = "beginmonth" Тогда
				НачалоПериода = НачалоМесяца(ТекущаяДатаСеанса());
				ОкончаниеПериода = КонецДня(ТекущаяДатаСеанса());
			ИначеЕсли Сообщение = "lastweek" Тогда
				НачалоПериода = НачалоНедели(НачалоНедели(ТекущаяДатаСеанса()) - 1);
				ОкончаниеПериода = НачалоНедели(ТекущаяДатаСеанса()) - 1;
			ИначеЕсли Сообщение = "thisweek" Тогда
				НачалоПериода = НачалоНедели(ТекущаяДатаСеанса());
				ОкончаниеПериода = КонецНедели(ТекущаяДатаСеанса());
			КонецЕсли;
			
			Если Сообщение = "arbitrary" Тогда
				ДобавитьВТекущийЗапрос(ИмяБота, TelegramId, "ОтчетПотраченноеВремя", 3, Данные);
				ТекущийЗапрос.стадия = 3;
			Иначе
				
				Данные.НачалоПериода = НачалоПериода;
				Данные.ОкончаниеПериода = ОкончаниеПериода;
				ТекущийЗапрос.Стадия = 4;
			КонецЕсли;
			
			ТекущийЗапрос.Данные = Данные;
			ОтчетПотраченноеВремя(ИмяБота, TelegramId, MessageId, ТекущийЗапрос, "");
			Возврат;
		ИначеЕсли ТекущийЗапрос.Стадия = 3 Тогда
			
			Если НЕ ЗначениеЗаполнено(Сообщение) Тогда // выводим календарь для ввода даты начала
				СтрокаИнтернетОтвета = "Укажите начало периода";
				
				НачалоКалендаря = ДобавитьМесяц(НачалоМесяца(ТекущаяДатаСеанса()), -1);
				
				СообщениеКалендаря = Новый Структура("cmd ,dateStart, date", "calendar", НачалоКалендаря- Дата(1,1,1), НачалоКалендаря- Дата(1,1,1));
				ОтправитьКалендарь = Истина;
			ИначеЕсли ЗначениеЗаполнено(Данные.НачалоПериода) Тогда // Запоминаем дату окончания и идем дальше
				Данные.ОкончаниеПериода = Дата(1, 1, 1) + Сообщение;
				ТекущийЗапрос.стадия = 4;
				ТекущийЗапрос.Данные = Данные;
				ОтчетПотраченноеВремя(ИмяБота, TelegramId, MessageId, ТекущийЗапрос, "");
				Возврат;
			Иначе // запоминаем дату Начала и выводим календарь для ввода даты окончания
				СтрокаИнтернетОтвета = "Укажите конец периода";
				Данные.началоПериода = Дата(1,1,1) + Сообщение;
				НачалоКалендаря = Данные.началоПериода - Дата(1,1,1);
				СообщениеКалендаря = Новый Структура("cmd ,dateStart, date", "calendar", НачалоКалендаря, НачалоКалендаря);
				ОтправитьКалендарь = Истина;
			КонецЕсли;
			
			ДобавитьВТекущийЗапрос(ИмяБота, TelegramId, "ОтчетПотраченноеВремя", 3, Данные);
		ИначеЕсли ТекущийЗапрос.Стадия = 4 Тогда
			
			Пользователь = Неопределено;
			Если ЗначениеЗаполнено(Данные.Пользователи) Тогда
				Пользователь = Справочники.Пользователи.ПолучитьСсылку(Новый УникальныйИдентификатор(Данные.Пользователи));
			КонецЕсли;
			
			ГруппаАдресации = Неопределено;
			Если ЗначениеЗаполнено(Данные.ГруппаАдресации) Тогда
				ГруппаАдресации = Справочники.ГруппыАдресации.ПолучитьСсылку(Новый УникальныйИдентификатор(Данные.ГруппаАдресации));
			КонецЕсли;
			
			Если НЕ Значениезаполнено(Пользователь) Тогда
				УчастникиГруппы = Справочники.ГруппыАдресации.ПолучитьУчастниковГруппыАдресации(ПараметрыСеанса.ТекущееПространство, ГруппаАдресации);
				Пользователи = Новый СписокЗначений;
				Для Каждого Участник Из УчастникиГруппы Цикл
					Пользователи.Добавить(Участник);
				КонецЦикла;
			иначе
				Пользователи = Пользователь;
			КонецЕсли;
			
			АнализПотраченногоВремени = Отчеты["АнализПотраченногоВремени"].Создать();
			Для Каждого Элемент Из АнализПотраченногоВремени.КомпоновщикНастроек.ПользовательскиеНастройки.Элементы Цикл
				Если Строка(Элемент.Параметр) = "ПериодОтчета" Тогда
					Элемент.Значение.ДатаНачала = Данные.НачалоПериода;
					Элемент.Значение.ДатаОкончания = Данные.ОкончаниеПериода;
				ИначеЕсли Строка(Элемент.Параметр) = "НаименованиеСотрудник" Тогда
					Элемент.Значение = Пользователи;
				ИначеЕсли Строка(Элемент.Параметр) = "НаименованиеОрганизация" Тогда
					Элемент.Значение = Справочники.Клиенты.ПолучитьСписокДоступныхПространствуКлиентов(ПараметрыСеанса.ТекущееПространство);
				КонецЕсли;
			КонецЦикла;
			
			ТД_ОписательнаяЧасть = Новый ТабличныйДокумент;
			
			АнализПотраченногоВремени.СкомпоноватьРезультат(ТД_ОписательнаяЧасть);
			
			ПутьКФайлу = ПолучитьИмяВременногоФайла();
			ТД_ОписательнаяЧасть.АвтоМасштаб=Истина;
			
			ТД_ОписательнаяЧасть.Записать(ПутьКФайлу, ТипФайлаТабличногоДокумента.PDF);
			
			Структура = Новый Структура("Имя,Путь", "Затраченное на задачи время с " + Формат(Данные.НачалоПериода, "ДФ=dd.MM") + " по " + Формат(Данные.ОкончаниеПериода, "ДФ=dd.MM") + ".pdf", ПутьКФайлу);
			ОтправитьВTelegramDocument(ИмяБота, TelegramId, Структура.Имя, Структура.Путь, "");
			ОтправитьНачалоРаботы = истина;
		КонецЕсли;
		
		ОтправитьВTelegramDeleteMessage(ИмяБота,TelegramId,MessageId);
		
		Если ОтправитьКалендарь Тогда
			ОткрытьКалендарь(ИмяБота, TelegramId, 0, СообщениеКалендаря, СтрокаИнтернетОтвета);
		Иначе
			ОтправитьВTelegramText(ИмяБота, TelegramId, 0, СтрокаИнтернетОтвета, reply_markup,Истина);
		КонецЕсли;
		
		Если ОтправитьНачалоРаботы Тогда
			
			НачалоРаботы(ИмяБота,TelegramId);
		КонецЕсли;
	Исключение
		ЗаписьЖурналаРегистрации("elapsedtime", УровеньЖурналаРегистрации.Ошибка,,, ОписаниеОшибки());
	КонецПопытки;
	
КонецПроцедуры






  

#Область ПриемИПервичнаяОбработкаВходящихСообщений   

Процедура ПрочитатьСообщениеTelegram(ИмяБота, Сообщение) Экспорт
	
	ДобавитьВИсториюЗапросов(ИмяБота,Сообщение);
	
	Попытка
		Если Сообщение.Свойство("callback_query") Тогда
			
			ВыполнитьИнлайнКомандуБота(ИмяБота, Сообщение.callback_query);
			
		ИначеЕсли Сообщение.Свойство("message")  Тогда
			
			Если Сообщение.message.Свойство("text") 
				ИЛИ Сообщение.message.Свойство("contact") Тогда
				
				ВыполнитьКомандуБота(ИмяБота, Сообщение.message);
				
			ИначеЕсли Сообщение.message.Свойство("photo") Или
				Сообщение.message.Свойство("document") Или
				Сообщение.message.Свойство("video") Или
				Сообщение.message.Свойство("voice") Тогда
				
				ИнформацияОФайле = ПринятьФайл(ИмяБота, Сообщение.message);
				
				TelegramId = Сообщение.message.chat.id;
				
				ВыполнитьОбработкуФайла(ИмяБота, TelegramId, ИнформацияОФайле);
			КонецЕсли;
		КонецЕсли;
	Исключение
		ЗаписьЖурналаРегистрации("Ошибка", УровеньЖурналаРегистрации.Ошибка,,, ОписаниеОшибки());
	КонецПопытки;
	
КонецПроцедуры

Процедура ПрочитатьСообщенияTelegram(ИмяБота, Обновления, Смещение)
	
	ДеревоЗн = Новый ДеревоЗначений();
	
	ЧтениеJSON = Новый ЧтениеJSON();
	ЧтениеJSON.УстановитьСтроку(Обновления);
	Результат = ПрочитатьJSON(ЧтениеJSON);
	ЧтениеJSON.Закрыть();
	
	Если НЕ Результат.ok Тогда
		Возврат;
	КонецЕсли;
	
	СписокСообщений = Результат.result;
	
	Если СписокСообщений.Количество() > 0 Тогда
		
		ЗаписьЖурналаРегистрации("Telegram.ПринятыеСообщения", УровеньЖурналаРегистрации.Информация,,,Обновления);
		
		Для каждого Сообщение Из СписокСообщений Цикл
			
			Смещение = Сообщение.update_id;
			
			ПрочитатьСообщениеTelegram(ИмяБота, Сообщение);
		КонецЦикла;
	Иначе
		
		Смещение = 0;
	КонецЕсли;
	
КонецПроцедуры

Процедура ВыполнитьИнлайнКомандуБота(ИмяБота, callback_query)
	
	TelegramId = callback_query.message.chat.id;
	MessageId  = callback_query.message.message_id;
	
	ТекущийЗапрос = ПолучитьТекущийЗапрос(TelegramId,ИмяБота);
	
	СотрудникЗарегистрированВTelegram(TelegramId);
	
	Если Лев(callback_query.data, 1) = "{" И
		Прав(callback_query.data, 1) = "}" Тогда
		
		ЧтениеJSON = Новый ЧтениеJSON();
		ЧтениеJSON.УстановитьСтроку(callback_query.data);
		ДанныеJSON = ПрочитатьJSON(ЧтениеJSON);
		ЧтениеJSON.Закрыть();
		
		Если ДанныеJSON.Свойство("deffered") Тогда
			
			ОтложенныйЗапросId = ДанныеJSON.deffered;
		КонецЕсли;         
		
		МассивНайденныхСтрок = ТаблицаПонимаемыхКоманд(ИмяБота,TelegramId).Строки.НайтиСтроки(Новый Структура("Имя", ДанныеJSON.cmd), Истина);		
	Иначе
		
		Поз = Найти(callback_query.data, "deffered:");
		
		Если Поз > 0 Тогда // Отложенный запрос. Пример: deffered:26952456
			
			ОтложенныйЗапросId = Сред(callback_query.data, Поз + 9);
		КонецЕсли;
		
		МассивНайденныхСтрок = ТаблицаПонимаемыхКоманд(ИмяБота,TelegramId).Строки.НайтиСтроки(Новый Структура("Имя", callback_query.data), Истина);
	КонецЕсли;
	
	Если Не ОтложенныйЗапросId = Неопределено Тогда
		
		ОтложенныйЗапрос = ПолучитьОтложенныйЗапрос(ОтложенныйЗапросId);
		
		Если Не ОтложенныйЗапрос = Неопределено Тогда
			
			ТекущийЗапрос = ОтложенныйЗапрос;	
		Иначе
			
			ТекущийЗапрос = ПолучитьТекущийЗапрос(TelegramId, ИмяБота);
		КонецЕсли;
	Иначе
		
		ТекущийЗапрос = ПолучитьТекущийЗапрос(TelegramId, ИмяБота);
	КонецЕсли; 
	
	Попытка
		
		Команда = Неопределено;
		
		Если МассивНайденныхСтрок.Количество() > 0 Тогда
			
			Команда = МассивНайденныхСтрок[0].Команда;
		ИначеЕсли Не ТекущийЗапрос = Неопределено Тогда
			
			Команда = ТекущийЗапрос.Команда;
		КонецЕсли;
		
		Если Не ОбработкаПрисоединенияКДокументам(ИмяБота, TelegramId, Команда) Тогда
			
			Возврат;
		КонецЕсли;
		
		Если Не Команда = Неопределено Тогда   
			
			Если Команда = "ОтменитьЗапрос" 
				Или callback_query.data = "cancel"
				Или (ТипЗнч(ДанныеJSON) = Тип("Структура")
				И ДанныеJSON.Свойство("cmd")
				И ДанныеJSON.cmd = "cancel"
				И ДанныеJSON.Свойство("deffered")
				И ЗначениеЗаполнено(ДанныеJSON.deffered)) Тогда
				
				ОтправитьВTelegramDeleteMessage(ИмяБота, TelegramId, MessageId);
				НачалоРаботы(ИмяБота, TelegramId);
				
				Если ТипЗнч(ДанныеJSON) = Тип("Структура")
					И ДанныеJSON.Свойство("cmd")
					И ДанныеJSON.cmd = "cancel"
					И ДанныеJSON.Свойство("deffered")
					И ЗначениеЗаполнено(ДанныеJSON.deffered) Тогда
					
					УдалитьОтложенныйЗапрос(ДанныеJSON.deffered); 
				КонецЕсли;
				Возврат;
			КонецЕсли;            
			
			Если Команда = "ПрисоединениеКДокументам" Тогда
				
				ПрисоединениеКДокументам(ИмяБота, TelegramId, MessageId, ТекущийЗапрос, callback_query.data);
				Возврат;
			КонецЕсли;
			
			Если СотрудникЗарегистрированВTelegram(TelegramId) Тогда
				
				Если Команда = "ОткрытьКалендарь" Тогда
					
					ОткрытьКалендарь(ИмяБота, TelegramId, MessageId, ДанныеJSON, callback_query.message.text);
				ИначеЕсли Команда = "ОткрытьВремя" Тогда
					
					ОткрытьВремя(ИмяБота, TelegramId, MessageId, ДанныеJSON);	
				ИначеЕсли Команда = "КомандаНазад" Тогда
					
					КомандаНазад(ИмяБота,TelegramId,MessageId);
				Иначе      
					
					Попытка
						
						Если ЗначениеЗаполнено(ДанныеJSON) Тогда
							
							Выполнить(Команда +"(ИмяБота, TelegramId, MessageId, ТекущийЗапрос, callback_query.data, ДанныеJSON)");
						Иначе
							
							Выполнить(Команда +"(ИмяБота, TelegramId, MessageId, ТекущийЗапрос, callback_query.data)");
						КонецЕсли;
					Исключение
						
						НачалоРаботы(ИмяБота, TelegramId);
					КонецПопытки;
				КонецЕсли; 
			Иначе
				
				Зарегистрироваться(ИмяБота, TelegramId, MessageId, ТекущийЗапрос, callback_query.data);
			КонецЕсли;
		Иначе
			
			НачалоРаботы(ИмяБота, TelegramId, MessageId);
		КонецЕсли;
		
	Исключение
		
		Ошибка = ОписаниеОшибки();
		
		Telegram.ОтправитьИнформационноеСообщение(511985368,"Ошибка: "+ ИмяБота + Символы.ПС + "База: " + ОбщийСерверПовтИсп.ПолучитьИмяБазы() + Символы.ПС + Ошибка);      
		
		МассивСообщенийПользователю = ПолучитьСообщенияПользователю(Истина);
		Сообщение = "";
		
		Для Каждого СообщениеПользователю Из МассивСообщенийПользователю Цикл
			
			Сообщение = Сообщение + СообщениеПользователю.Текст + Символы.ПС;
		КонецЦикла;
		
		Если Не ПустаяСтрока(Сообщение) Тогда
			
			Сообщение    = Лев(Сообщение, СтрДлина(Сообщение) - 1);
			reply_markup = СписокКоманд(ИмяБота, TelegramId);
			
			ОтправитьВTelegramText(ИмяБота, TelegramId, MessageId, Сообщение, reply_markup);
			
			ЗаписьЖурналаРегистрации("Telegram.ВыполнитьИнлайнКомандуБота", УровеньЖурналаРегистрации.Ошибка,,,"Сообщение пользователю:" + Символы.ПС + Сообщение);
		КонецЕсли;
	КонецПопытки;
	
КонецПроцедуры

Процедура ВыполнитьКомандуБота(ИмяБота, message)
	
	TelegramId = message.chat.id;
	
	MessageId = РегистрыСведений.TelegramПоследнееСообщение.ПолучитьMessageId(ИмяБота,TelegramId).MessageId;
	
	СотрудникЗарегистрированВTelegram(TelegramId);
	
	Попытка
		
		ТекущийЗапрос = ПолучитьТекущийЗапрос(TelegramId, ИмяБота);
		
		Если message.Свойство("text") Тогда
			Сообщение     = message.text;
		КонецЕсли;
		
		Если ТекущийЗапрос = Неопределено Тогда
			
			Команда = "";
		Иначе
			
			Команда = ТекущийЗапрос.Команда;
		КонецЕсли;
		
		// Если при присоединении отправили что то в чат
		Если Команда = "ПрисоединениеКДокументам" Тогда
			
			Команда = ""
		КонецЕсли;
		
		Если Не ОбработкаПрисоединенияКДокументам(ИмяБота,TelegramId,Команда) Тогда
			
			Возврат;
		КонецЕсли; 
		
		Если Сообщение = "/start"
			Или Сообщение = "/cancel" Тогда
			
			НачалоРаботы(ИмяБота, TelegramId);  
			Возврат;
		КонецЕсли;
		
		Если Не ТекущийЗапрос = Неопределено И Сообщение = "back" И ТекущийЗапрос.Стадия > 0 Тогда
			
			КомандаНазад(ИмяБота,ТекущийЗапрос);
		ИначеЕсли  Сообщение = "back" Тогда			
			
			НачалоРаботы(ИмяБота, TelegramId, MessageId);
		ИначеЕсли НЕ ТекущийЗапрос = Неопределено
			И ТекущийЗапрос.Команда = "Зарегистрироваться" Тогда
			Зарегистрироваться(ИмяБота, TelegramId, MessageId, ТекущийЗапрос, message);
			Возврат;
		КонецЕсли;			
		
		Если СотрудникЗарегистрированВTelegram(TelegramId) И
			Не ТекущийЗапрос = Неопределено Тогда     
			
			Попытка
				
				Выполнить(ТекущийЗапрос.Команда + "(ИмяБота, TelegramId, MessageId, ТекущийЗапрос, Сообщение)");
			Исключение 
				НачалоРаботы(ИмяБота, TelegramId, MessageId);
			КонецПопытки;
		Иначе
			НачалоРаботы(ИмяБота, TelegramId);
		КонецЕсли;
		
	Исключение
		
		МассивСообщенийПользователю = ПолучитьСообщенияПользователю(Истина);
		Сообщение = "";
		
		Ошибка = ОписаниеОшибки();
		
		Telegram.ОтправитьИнформационноеСообщение(511985368,"Ошибка: "+ ИмяБота + Символы.ПС + "База: " + ОбщийСерверПовтИсп.ПолучитьИмяБазы() + Символы.ПС + Ошибка);
		
		Для Каждого СообщениеПользователю Из МассивСообщенийПользователю Цикл
			
			Сообщение = Сообщение + СообщениеПользователю.Текст + Символы.ПС;
		КонецЦикла;
		
		Если Не ПустаяСтрока(Сообщение) Тогда
			
			Сообщение = Лев(Сообщение, СтрДлина(Сообщение) - 1);
			
			ОтправитьВTelegramText(ИмяБота, TelegramId, 0, Сообщение);
			
			ЗаписьЖурналаРегистрации("Telegram.ВыполнитьКомандуБота", УровеньЖурналаРегистрации.Ошибка,,,"Сообщение пользователю:" + Символы.ПС + Сообщение);
		КонецЕсли;
	КонецПопытки;
	
КонецПроцедуры

#КонецОбласти  

#Область ИсходящаяОтправкаСообщенийФайловИУведомлений 

//ОтправитьИнформационноеСообщение
//
// Параметры:
//	Получатели - Справочник.Пользователи, Справочник.ДолжностныеСекции, Массив - Получатели сообщения
//	ТекстСообщения - Строка - Текст сообщения
//
Процедура ОтправитьИнформационноеСообщение(Знач Получатели, ТекстСообщения) Экспорт
	
	Если Не Константы.ИспользоватьTelegram.Получить() ИЛИ ТипЗнч(Получатели) = Тип("Строка") Тогда
		
		Возврат;
	КонецЕсли;
	
	Если ТипЗнч(Получатели) = Тип("СправочникСсылка.Пользователи") Тогда
		
		Получатели = ОбщегоНазначенияКлиентСервер.ЗначениеВМассиве(Получатели.TelegramId);
	КонецЕсли;
	
	Если ТипЗнч(Получатели) = Тип("Число") Тогда
		
		Получатели = ОбщегоНазначенияКлиентСервер.ЗначениеВМассиве(Получатели);
	КонецЕсли;
	
	Для Каждого Получатель Из Получатели Цикл
		
		Если Получатель = 0 Тогда
			
			Продолжить;
		КонецЕсли;
		
		ИмяБота = ПолучитьИмяБота();
		
		ПоследнееСообщение = ПолучитьПоследнееСообщение(ИмяБота, Получатель);
		
		Если ПоследнееСообщение = ТекстСообщения Тогда
			
			Возврат;
		КонецЕсли;
		
		ОтправитьВTelegramText(ИмяБота, Получатель, 0, ТекстСообщения,,Истина);
	КонецЦикла;
	
КонецПроцедуры

Процедура ОтправитьНапоминание() Экспорт
	
	Если Не Константы.ИспользоватьTelegram.Получить() Тогда
		
		Возврат;
	КонецЕсли;
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
	"ВЫБРАТЬ
	|	TelegramОповещения.TelegramId КАК TelegramId,
	|	TelegramОповещения.ВремяОтправки КАК ВремяОтправки,
	|	TelegramОповещения.ИмяБота КАК ИмяБота,
	|	TelegramОповещения.ТекстСообщения КАК ТекстСообщения,
	|	TelegramОповещения.ИдентификаторОтложенногоЗапроса КАК ИдентификаторОтложенногоЗапроса
	|ИЗ
	|	РегистрСведений.TelegramОповещения КАК TelegramОповещения";
	
	РезультатЗапроса = Запрос.Выполнить();
	
	ВыборкаДетальныеЗаписи = РезультатЗапроса.Выбрать();
	
	Пока ВыборкаДетальныеЗаписи.Следующий() Цикл
		
		Ид = ОтправитьВTelegramText(ВыборкаДетальныеЗаписи.ИмяБота,ВыборкаДетальныеЗаписи.TelegramId,0,ВыборкаДетальныеЗаписи.ТекстСообщения,"",Истина);
		
		Если Ид > 0 Тогда
			
			ЗаписьУдалить = РегистрыСведений.TelegramОповещения.СоздатьМенеджерЗаписи();
			ЗаполнитьЗначенияСвойств(ЗаписьУдалить,ВыборкаДетальныеЗаписи);
			ЗаписьУдалить.Удалить();		
		КонецЕсли;
	КонецЦикла;
	
	
КонецПроцедуры

Функция ОтправитьВTelegramText(ИмяБота, TelegramId, MessageId, знач СтрокаСообщения, reply_markup = "", parse_mode_HTML = Ложь, ИдентификаторОтложенногоЗапроса = 0, ПоследняяПопытка = Ложь) Экспорт
	
	Если parse_mode_HTML Тогда
		
		СтрокаСообщения = ЗаменитьСкобкиНаСлова(СтрокаСообщения);
	КонецЕсли;
	
	reply_markup = СтрЗаменить(reply_markup,"\\","\");
	
	Если СтрДлина(СтрокаСообщения) > 3600 Тогда
		
		КоличествоСообщений = Цел(СтрДлина(СтрокаСообщения)/3600);
		
		текПозиция = 0;
		
		Для Сч = 1 По КоличествоСообщений + 1 Цикл
			
			текСтрока = Сред(СтрокаСообщения,текПозиция,3600);
			
			Если СтрДлина(текСтрока) > 0 Тогда
				
				ПереносСтроки = СтрНайти(текСтрока,Символы.ПС,НаправлениеПоиска.СКонца);
				
				Если ПереносСтроки > 0 Тогда
					
					текПозиция = ПереносСтроки + текПозиция;
					текСтрока = Лев(текСтрока,ПереносСтроки);
				Иначе
					
					текПозиция = 3600;
				КонецЕсли;
				
				MessageIdPart = ОтправитьВTelegramText(ИмяБота, TelegramId, 0, текСтрока, reply_markup, parse_mode_HTML);
			КонецЕсли;                                                                                                                                                                				
		КонецЦикла;
		Возврат MessageIdPart;
	КонецЕсли;
	
	Boundary = "----"+Строка(Новый УникальныйИдентификатор());
	
	//Определяем массив для процедуры ОбъединитьФайлы 
	МассивФайловДляОбъединения = Новый Массив; 
	
	//Формируем начальный фрагмент файла POST-запроса 
	ИмяФайлаОтправкиНачало = ПолучитьИмяВременногоФайла("txt"); 
	ФайлОтправкиНачало = Новый ЗаписьТекста(ИмяФайлаОтправкиНачало, КодировкаТекста.UTF8); 
	
	ТекстДляОтправки = "";
	
	// Чат
	ТекстДляОтправки = ТекстДляОтправки + "--"+Boundary + Символы.ПС;    
	ТекстДляОтправки = ТекстДляОтправки + "Content-Disposition: form-data; name=""chat_id""" + Символы.ПС + Символы.ПС;    
	ТекстДляОтправки = ТекстДляОтправки + Формат(TelegramId, "ЧГ=") + Символы.ПС;
	
	Если MessageId > 0 Тогда
		
		// Идентификатор сообщения
		ТекстДляОтправки = ТекстДляОтправки + "--"+Boundary + Символы.ПС;    
		ТекстДляОтправки = ТекстДляОтправки + "Content-Disposition: form-data; name=""message_id""" + Символы.ПС + Символы.ПС;    
		ТекстДляОтправки = ТекстДляОтправки + Формат(MessageId, "ЧГ=") + Символы.ПС;
	КонецЕсли;
	
	// Чат
	ТекстДляОтправки = ТекстДляОтправки + "--"+Boundary + Символы.ПС;    
	ТекстДляОтправки = ТекстДляОтправки + "Content-Disposition: form-data; name=""chat_id""" + Символы.ПС + Символы.ПС;    
	ТекстДляОтправки = ТекстДляОтправки + Формат(TelegramId, "ЧГ=") + Символы.ПС;
	
	
	Если parse_mode_HTML Тогда
		
		// parse_mode
		ТекстДляОтправки = ТекстДляОтправки + "--"+Boundary + Символы.ПС;    
		ТекстДляОтправки = ТекстДляОтправки + "Content-Disposition: form-data; name=""parse_mode""" + Символы.ПС + Символы.ПС;    
		ТекстДляОтправки = ТекстДляОтправки + "HTML" + Символы.ПС;
	КонецЕсли;
	
	// Текст
	ТекстДляОтправки = ТекстДляОтправки + "--"+Boundary + Символы.ПС;    
	ТекстДляОтправки = ТекстДляОтправки + "Content-Disposition: form-data; name=""text""" + Символы.ПС + Символы.ПС;    
	ТекстДляОтправки = ТекстДляОтправки + СтрокаСообщения + Символы.ПС;
	
	// Кнопки для ответа
	
	ТекстДляОтправки = ТекстДляОтправки + "--"+Boundary + Символы.ПС;    
	ТекстДляОтправки = ТекстДляОтправки + "Content-Disposition: form-data; name=""reply_markup""" + Символы.ПС + Символы.ПС;    
	ТекстДляОтправки = ТекстДляОтправки + reply_markup + Символы.ПС;
	
	
	ТекстДляОтправки = ТекстДляОтправки + "--"+Boundary+"--";
	
	ЗаписьЖурналаРегистрации("Telegram.ОтправитьВTelegramText", УровеньЖурналаРегистрации.Информация,,,ТекстДляОтправки);
	
	ФайлОтправкиНачало.ЗаписатьСтроку(ТекстДляОтправки);
	ФайлОтправкиНачало.Закрыть();
	
	Если MessageId > 0 Тогда
		Ресурс = "/bot"+ДанныеБота(ИмяБота).Токен+"/editMessageText";
	Иначе
		Ресурс = "/bot"+ДанныеБота(ИмяБота).Токен+"/sendMessage";
	КонецЕсли;
	
	HTTPЗапрос = Новый HTTPЗапрос(Ресурс);
