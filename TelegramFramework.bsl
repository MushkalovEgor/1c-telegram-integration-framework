	Если Токен = "токен" Тогда
		
		Возврат "названиебота";
				
	КонецЕсли;
	
	Возврат Неопределено;
	
КонецФункции

Функция СотрудникЗарегистрированВTelegram(TelegramId)
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
	"ВЫБРАТЬ разрешенные
	|	Сотрудники.Ссылка
	|ИЗ
	|	Справочник.Пользователи КАК Сотрудники
	|ГДЕ
	|	НЕ Сотрудники.ПометкаУдаления
	|	И НЕ Сотрудники.Архивный
	|	И Сотрудники.TelegramId = &TelegramId";
	
	Запрос.УстановитьПараметр("TelegramId", TelegramId);
	
	Выборка = Запрос.Выполнить().Выбрать();
	
	Если Выборка.Следующий() Тогда
		
		Если ПараметрыСеанса.Сотрудник <> Выборка.Ссылка Тогда
			
			ПараметрыСеанса.Сотрудник = Выборка.Ссылка;
			
			ПараметрыСеанса.ТекущееПространство = РегистрыСведений.TelegramТекущееПространство.ПолучитьТекущееПространствоПользователя(TelegramId);
			
		КонецЕсли;
		
		Возврат Истина;
	КонецЕсли;
	
	Возврат Ложь;
	
КонецФункции

Функция ПолучитьЗначениеСвойстваПользователя(Свойство, Сотрудник = Неопределено)
	
	Если Сотрудник = Неопределено Тогда
		Сотрудник = ПараметрыСеанса.Сотрудник;
	КонецЕсли;
	
	ПрименятьРазделениеПоПространствам = ОбщегоНазначения.ЗначениеРеквизитаОбъекта(Свойство, "ПрименятьРазделениеПоПространствам") = Истина;
	
	Запрос = Новый Запрос;
	Запрос.Текст = "ВЫБРАТЬ
	|	СвойстваСотрудника.Значение КАК Значение
	|ИЗ
	|	РегистрСведений.СвойстваСотрудника КАК СвойстваСотрудника
	|ГДЕ
	|	СвойстваСотрудника.Свойство = &Свойство
	|	И СвойстваСотрудника.Свойство.ДляБота
	|	И СвойстваСотрудника.Сотрудник = &Сотрудник";
	Запрос.УстановитьПараметр("Свойство", Свойство);
	Запрос.УстановитьПараметр("Сотрудник", Сотрудник);
	Если ПрименятьРазделениеПоПространствам Тогда
		Запрос.Текст = запрос.Текст + " И СвойстваСотрудника.Пространство = &Пространство";
		Запрос.УстановитьПараметр("Пространство", ПараметрыСеанса.ТекущееПространство);
	КонецЕсли;
	
	РезультатЗапроса = Запрос.Выполнить();
	Если РезультатЗапроса.Пустой() Тогда
		
		ЗначениеПоУмолчанию = ПланыВидовХарактеристик.СвойстваСотрудника[Свойство.ИмяПредопределенныхДанных].ТипЗначения.ПривестиЗначение();
		
		НоваяЗапись = РегистрыСведений.СвойстваСотрудника.СоздатьМенеджерЗаписи();
		НоваяЗапись.Пространство = ?(ПрименятьРазделениеПоПространствам, ПараметрыСеанса.ТекущееПространство, Справочники.РабочиеПространства.ПустаяСсылка());
		НоваяЗапись.Сотрудник = Сотрудник;
		НоваяЗапись.Свойство = Свойство;
		НоваяЗапись.Значение = ЗначениеПоУмолчанию;
		НоваяЗапись.Период = ТекущаяДатаСеанса();
		НоваяЗапись.Записать();
		
		Возврат ЗначениеПоУмолчанию;
		
	Иначе 
		Выборка = РезультатЗапроса.Выбрать();
		Выборка.Следующий();
		
		Возврат Выборка.Значение;
		
	КонецЕсли;
	
КонецФункции

