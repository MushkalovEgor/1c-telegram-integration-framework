	НоваяКоманда.Имя      = "stoptask";
	НоваяКоманда.Команда  = "СтопЗадачи";
	НоваяКоманда.Описание = "Стоп задачи";
	НоваяКоманда.Автокоманда = Истина;
	
	НоваяКоманда = ДеревоЗначений.Строки.Добавить();
	НоваяКоманда.Имя      = "applytask";
	НоваяКоманда.Команда  = "ЗавершениеЗадачи";
	НоваяКоманда.Описание = "\u2705 Завершение задачи";
	НоваяКоманда.Автокоманда = Истина; 
	
	НоваяКоманда = ДеревоЗначений.Строки.Добавить();
	НоваяКоманда.Имя      = "applytaskSupport";
	НоваяКоманда.Команда  = "ЗавершениеЗадачиТП";
	НоваяКоманда.Описание = "\u2705 Завершение задач";
	НоваяКоманда.Автокоманда = Истина;    
	
	НоваяКоманда = ДеревоЗначений.Строки.Добавить();
	НоваяКоманда.Имя      = "oncontrol";
	НоваяКоманда.Команда  = "ЗадачиНаКонтроле";
	НоваяКоманда.Описание = "\ud83d\udd10 На контроле";
