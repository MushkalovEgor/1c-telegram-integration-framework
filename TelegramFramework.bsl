Процедура КомандаНазад(ИмяБота,TelegramId,MessageId = 0)
	
	Если MessageId > 0 Тогда
		
		ОтправитьВTelegramDeleteMessage(ИмяБота,TelegramId, MessageId);
	КонецЕсли;
	
	УдалитьПоследнююЗаписьИстории(ИмяБота, TelegramId);
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
	"ВЫБРАТЬ
	|	ЕСТЬNULL(КОЛИЧЕСТВО(TelegramИсторияЗапросов.Период), 0) КАК Количество
	|ИЗ
	|	РегистрСведений.TelegramИсторияЗапросов КАК TelegramИсторияЗапросов
	|ГДЕ
	|	TelegramИсторияЗапросов.TelegramId = &TelegramId
	|	И TelegramИсторияЗапросов.ИмяБота = &ИмяБота
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	TelegramИсторияЗапросов.Период КАК Период,
	|	TelegramИсторияЗапросов.TelegramId КАК TelegramId,
	|	TelegramИсторияЗапросов.Сообщение КАК Сообщение,
	|	TelegramИсторияЗапросов.Стадия КАК Стадия
	|ИЗ
	|	РегистрСведений.TelegramИсторияЗапросов.СрезПоследних(, TelegramId = &TelegramId) КАК TelegramИсторияЗапросов";
	
	Запрос.УстановитьПараметр("TelegramId", TelegramId);
	Запрос.УстановитьПараметр("ИмяБота", ИмяБота);
	
	РезультатыЗапроса = Запрос.ВыполнитьПакет();
	
	Выборка1 = РезультатыЗапроса[0].Выбрать();
	Выборка1.Следующий();
	
	Если Не Выборка1.Количество Тогда
		
		ОтправитьВTelegramText(ИмяБота, TelegramId, MessageId, "❌ Запрос был отменен");
		
		НачалоРаботы(ИмяБота, TelegramId);
		Возврат;
	КонецЕсли;
	
	Выборка2 = РезультатыЗапроса[1].Выбрать();
	Выборка2.Следующий();
	
	Сообщение = Выборка2.Сообщение.Получить();
	Стадия    = Выборка2.Стадия;
	
	МенеджерЗаписи = РегистрыСведений.TelegramТекущиеЗапросы.СоздатьМенеджерЗаписи();
	МенеджерЗаписи.TelegramId = TelegramId;
	МенеджерЗаписи.ИмяБота = ИмяБота;
	
	Если Выборка1.Количество = 1 Тогда
		
		МенеджерЗаписи.Удалить();
	Иначе
		
		МенеджерЗаписи.Прочитать();
		
		Если МенеджерЗаписи.Выбран() Тогда
			
			МенеджерЗаписи.Стадия = Стадия;
			МенеджерЗаписи.Записать(Истина);
		КонецЕсли;
	КонецЕсли;
	
	Если Сообщение.Свойство("data") Тогда
		
		ВыполнитьИнлайнКомандуБота(ИмяБота, Сообщение);
		
	ИначеЕсли Сообщение.Свойство("text") Тогда
		
		ВыполнитьКомандуБота(ИмяБота, Сообщение);
	КонецЕсли;
	
КонецПроцедуры

Функция ВызовПереходаККоманде(ПереходККоманде)
	
	Параметры = "(";
	Команда = "";
	
	Для Каждого текПараметр Из ПереходККоманде Цикл
		
		Если текПараметр.Ключ = "Команда" Тогда
			
			Команда = текПараметр.Значение;
		Иначе
			
			Параметры = Параметры + "Данные.ПереходККоманде." + текПараметр.Ключ + ",";
		КонецЕсли;
	КонецЦикла; 
	
	Параметры = Лев(Параметры, СтрДлина(Параметры)-1) + ")";
	
	Возврат Команда + Параметры;
