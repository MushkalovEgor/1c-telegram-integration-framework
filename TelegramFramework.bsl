Функция ДобавитьВОтложенныйЗапрос(ПараметрыОтложенногоЗапроса) Экспорт   
	
	ТребуемыеПараметры = Новый Массив;
	
	ТребуемыеПараметры.Добавить("ИмяБота");
	ТребуемыеПараметры.Добавить("TelegramId");
	ТребуемыеПараметры.Добавить("Команда");
	ТребуемыеПараметры.Добавить("ИдентификаторЗапроса");    
	
	ПараметрыПоУмолчанию = Новый ТаблицаЗначений();
	ПараметрыПоУмолчанию.Колонки.Добавить("Параметр");
	ПараметрыПоУмолчанию.Колонки.Добавить("Значение");  
	
	нСтр = ПараметрыПоУмолчанию.Добавить();
	нСтр.Параметр = "Стадия";
	нСтр.Значение = 0;
	
	нСтр = ПараметрыПоУмолчанию.Добавить();
	нСтр.Параметр = "Данные";
	нСтр.Значение = Неопределено;
	
	нСтр = ПараметрыПоУмолчанию.Добавить();
	нСтр.Параметр = "ВремяЖизниЗапроса";
	нСтр.Значение = 300;
	
	нСтр = ПараметрыПоУмолчанию.Добавить();
	нСтр.Параметр = "Сообщение";
	нСтр.Значение = "";
	
	нСтр = ПараметрыПоУмолчанию.Добавить();
	нСтр.Параметр = "MessageId";
	нСтр.Значение = 0;
	
	нСтр = ПараметрыПоУмолчанию.Добавить();
	нСтр.Параметр = "ОтложеннаяОтправка";
	нСтр.Значение = Неопределено;
	
	нСтр = ПараметрыПоУмолчанию.Добавить();
	нСтр.Параметр = "ДанныеОтложеннойОтправки";
	нСтр.Значение = Неопределено;
	
	Для Каждого текПараметр Из ТребуемыеПараметры Цикл
		
		Если Не ПараметрыОтложенногоЗапроса.Свойство(текПараметр)
			Или Не ЗначениеЗаполнено(ПараметрыОтложенногоЗапроса[текПараметр]) Тогда
			
			ОбщегоНазначенияКлиентСервер.СообщитьПользователю("Не заполнен или отсутсвует параметр "+ текПараметр);
			Возврат Ложь;
		КонецЕсли;
	КонецЦикла;  
	
	Для Каждого текПараметр Из ПараметрыПоУмолчанию Цикл
		
		Если Не ПараметрыОтложенногоЗапроса.Свойство(текПараметр.Параметр) Тогда
			
			ПараметрыОтложенногоЗапроса.Вставить(текПараметр.Параметр,текПараметр.Значение);
		ИначеЕсли Не ЗначениеЗаполнено(ПараметрыОтложенногоЗапроса[текПараметр.Параметр]) Тогда
			
			ПараметрыОтложенногоЗапроса[текПараметр.Параметр] = текПараметр.Значение;
		КонецЕсли;
	КонецЦикла;
	
	Если ПараметрыОтложенногоЗапроса.ОтложеннаяОтправка = Неопределено
		Или ПараметрыОтложенногоЗапроса.ОтложеннаяОтправка <= ТекущаяДата() Тогда
		
		ФоновыеЗадания.Выполнить("Telegram.ДобавитьВОтложенныйЗапросСОтправкой",ОбщегоНазначенияКлиентСервер.ЗначениеВМассиве(ПараметрыОтложенногоЗапроса));
	Иначе
		
		ФоновыеЗадания.Выполнить("Telegram.ДобавитьВОтложенныйЗапросБезОтправки",ОбщегоНазначенияКлиентСервер.ЗначениеВМассиве(ПараметрыОтложенногоЗапроса));
	КонецЕсли;
	
КонецФункции

Процедура ДобавитьВОтложенныйЗапросСОтправкой(Параметры) Экспорт
	
	УстановитьПривилегированныйРежим(Истина);
	
	Если Параметры.ВремяЖизниЗапроса = Неопределено Тогда
		
		Параметры.ВремяЖизниЗапроса = 300;
	КонецЕсли;  
	
	Если Параметры.ДанныеОтложеннойОтправки = Неопределено Тогда
		
		Возврат;
	КонецЕсли;    
	
	reply_markup = "";
	
	Если Параметры.ДанныеОтложеннойОтправки.Свойство("reply_markup") Тогда
		
		reply_markup = Параметры.ДанныеОтложеннойОтправки.reply_markup;
	ИначеЕсли Параметры.Свойство("reply_markup") Тогда
		
		reply_markup = Параметры.reply_markup;	
	КонецЕсли;
	
	Попытка
		
		MessageId = ОтправитьВTelegramText(Параметры.ИмяБота,Параметры.TelegramId,0,Параметры.Сообщение,reply_markup,Истина);
		
		Если MessageId > 0 Тогда
			
			НачатьТранзакцию(РежимУправленияБлокировкойДанных.Управляемый);
			
			Блокировка = Новый БлокировкаДанных;
			ЭлементБлокировки = Блокировка.Добавить("РегистрСведений.TelegramОтложенныеЗапросы");
			ЭлементБлокировки.Режим = РежимБлокировкиДанных.Исключительный;
			ЭлементБлокировки.УстановитьЗначение("TelegramId", Параметры.TelegramId);
			ЭлементБлокировки.УстановитьЗначение("ИмяБота", Параметры.ИмяБота);
			
			Блокировка.Заблокировать();  
			
			МенеджерЗаписи = РегистрыСведений.TelegramОтложенныеЗапросы.СоздатьМенеджерЗаписи();
			
			ЗаполнитьЗначенияСвойств(МенеджерЗаписи, Параметры);
			
			МенеджерЗаписи.Данные		= ?(Параметры.Данные = Неопределено, Новый ХранилищеЗначения(Новый Структура()), Новый ХранилищеЗначения(Параметры.Данные));
			
			МенеджерЗаписи.Время		= ТекущаяДата();
			
			МенеджерЗаписи.ДанныеОтложенногоЗапроса = Новый ХранилищеЗначения(Параметры.ДанныеОтложеннойОтправки);
			МенеджерЗаписи.Отправлено	= Ложь;
			
			МенеджерЗаписи.Идентификатор		= Параметры.ИдентификаторЗапроса;
			МенеджерЗаписи.MessageId			= MessageId;   
			МенеджерЗаписи.Отправлено	= Истина;
			
			МенеджерЗаписи.Записать(Истина);
			
			ЗафиксироватьТранзакцию();   
		КонецЕсли;
	Исключение
		
	КонецПопытки;
	
КонецПроцедуры

Процедура ДобавитьВОтложенныйЗапросБезОтправки(Параметры) Экспорт
	
	УстановитьПривилегированныйРежим(Истина);
	
	Если Параметры.ВремяЖизниЗапроса = Неопределено Тогда
		
		Параметры.ВремяЖизниЗапроса = 300;
	КонецЕсли;    
	
	НачатьТранзакцию(РежимУправленияБлокировкойДанных.Управляемый);
	
	Блокировка = Новый БлокировкаДанных;
	ЭлементБлокировки = Блокировка.Добавить("РегистрСведений.TelegramОтложенныеЗапросы");
	ЭлементБлокировки.Режим = РежимБлокировкиДанных.Исключительный;
	ЭлементБлокировки.УстановитьЗначение("TelegramId", Параметры.TelegramId);
	ЭлементБлокировки.УстановитьЗначение("ИмяБота", Параметры.ИмяБота);
	
	Блокировка.Заблокировать();  
	
	МенеджерЗаписи = РегистрыСведений.TelegramОтложенныеЗапросы.СоздатьМенеджерЗаписи();
	
	ЗаполнитьЗначенияСвойств(МенеджерЗаписи, Параметры);
	
