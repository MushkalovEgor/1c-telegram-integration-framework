Процедура ОткрытьКалендарь(ИмяБота, TelegramId, MessageId, Сообщение, Заголовок = "Выберите дату", ОтображатьТекущееДатуИВремя = Ложь) Экспорт
	
	Если Сообщение = Неопределено Тогда
		
		Сообщение = Новый Структура("cmd,dateStart,date", "calendar", ТекущаяДата() - Дата(1,1,1), ТекущаяДата() - Дата(1,1,1));
	КонецЕсли;
	
	КалендарьТЗ = ОбщийСервер.ПолучитьКалендарьЗаПериод(НачалоДня(Дата(1,1,1) + Макс(Сообщение.dateStart, Сообщение.date)), КонецМесяца(Дата(1,1,1) + Сообщение.date), Истина, Истина);
	
	ЗаписьJSON = СоздатьInlineKeyboard();
	
	ЗаписьJSON.ЗаписатьНачалоМассива();
	
	Если НачалоМесяца(Дата(1,1,1) + Сообщение.date - 1) < (Дата(1,1,1) + Сообщение.dateStart) Тогда
		
		date = Сообщение.dateStart;
	Иначе
		date = НачалоМесяца(Дата(1,1,1) + Сообщение.date - 1) - Дата(1,1,1);
	КонецЕсли;
	
	ДобавитьInlineКнопку(ЗаписьJSON, "<", JSONДанныеКалендаря("calendar", Сообщение.dateStart, date));
	ДобавитьInlineКнопку(ЗаписьJSON, Формат(Дата(1,1,1) + Сообщение.date, "ДФ='MMM'"), JSONДанныеКалендаря("calendar", Сообщение.dateStart, Сообщение.date));
	ДобавитьInlineКнопку(ЗаписьJSON, ">", JSONДанныеКалендаря("calendar", Сообщение.dateStart, КонецМесяца(Дата(1,1,1) + Сообщение.date) + 1 - Дата(1,1,1)));
	
	Если НачалоМесяца(ДобавитьМесяц(Дата(1,1,1) + Сообщение.date, -12)) < (Дата(1,1,1) + Сообщение.dateStart) Тогда
		
		date = Сообщение.dateStart;
	Иначе
		date = НачалоМесяца(ДобавитьМесяц(Дата(1,1,1) + Сообщение.date, -12)) - Дата(1,1,1);
	КонецЕсли;
	
	ДобавитьInlineКнопку(ЗаписьJSON, "<", JSONДанныеКалендаря("calendar", Сообщение.dateStart, date));
	ДобавитьInlineКнопку(ЗаписьJSON, Формат(Дата(1,1,1) + Сообщение.date, "ДФ='yyyy'"), JSONДанныеКалендаря("calendar", Сообщение.dateStart, Сообщение.date));
	ДобавитьInlineКнопку(ЗаписьJSON, ">", JSONДанныеКалендаря("calendar", Сообщение.dateStart, НачалоМесяца(ДобавитьМесяц(Дата(1,1,1) + Сообщение.date, 12)) - Дата(1,1,1)));
	
	ЗаписьJSON.ЗаписатьКонецМассива();
	
	ЗаписьJSON.ЗаписатьНачалоМассива();
	ДобавитьInlineКнопку(ЗаписьJSON, "Пн", 0);
	ДобавитьInlineКнопку(ЗаписьJSON, "Вт", 0);
	ДобавитьInlineКнопку(ЗаписьJSON, "Ср", 0);
	ДобавитьInlineКнопку(ЗаписьJSON, "Чт", 0);
	ДобавитьInlineКнопку(ЗаписьJSON, "Пт", 0);
	ДобавитьInlineКнопку(ЗаписьJSON, "Сб", 0);
	ДобавитьInlineКнопку(ЗаписьJSON, "Вс", 0);
	ЗаписьJSON.ЗаписатьКонецМассива();
	
	НомерНедели = Неопределено;
	МассивДней  = Неопределено;
	
	Для Каждого СтрокаКалендаря Из КалендарьТЗ Цикл
		
		Если Не НомерНедели = (СтрокаКалендаря.НомерНедели - 1) Тогда
			
			Если Не НомерНедели = Неопределено Тогда
				
				Для ДеньНедели = 0 По 6 Цикл
					Если МассивДней[ДеньНедели] = Неопределено Тогда
						
						ДобавитьInlineКнопку(ЗаписьJSON, " ", JSONДанныеКалендаря("calendar", Сообщение.dateStart, Сообщение.date));
					Иначе
						
						ДобавитьInlineКнопку(ЗаписьJSON, "" + День(МассивДней[ДеньНедели]), МассивДней[ДеньНедели] - Дата(1,1,1));
					КонецЕсли;
				КонецЦикла;
				
				ЗаписьJSON.ЗаписатьКонецМассива();
			КонецЕсли;
			
			ЗаписьJSON.ЗаписатьНачалоМассива();
			
			МассивДней  = Новый Массив(7);
			НомерНедели = СтрокаКалендаря.НомерНедели - 1;
		КонецЕсли;
		
		МассивДней[СтрокаКалендаря.ДеньНедели - 1] = СтрокаКалендаря.Дата;
	КонецЦикла;
	
	Для ДеньНедели = 0 По 6 Цикл
		Если МассивДней[ДеньНедели] = Неопределено Тогда
			ДобавитьInlineКнопку(ЗаписьJSON, " ", JSONДанныеКалендаря("calendar", Сообщение.dateStart, Сообщение.date));
		Иначе
			ДобавитьInlineКнопку(ЗаписьJSON, День(МассивДней[ДеньНедели]), МассивДней[ДеньНедели] - Дата(1,1,1));
		КонецЕсли;
	КонецЦикла;
	
	ЗаписьJSON.ЗаписатьКонецМассива();
	
	Если ОтображатьТекущееДатуИВремя Тогда
		
		ЗаписьJSON.ЗаписатьНачалоМассива();
		ДобавитьInlineКнопку(ЗаписьJSON, "Текущая дата и время", JSONДанныеКалендаря("calendar", ТекущаяДата(), ТекущаяДата()));
		ЗаписьJSON.ЗаписатьКонецМассива();
	КонецЕсли;
	
	reply_markup = ДобавитьInlineКнопкуОтменить(ЗаписьJSON);
	
	ОтправитьВTelegramText(ИмяБота, TelegramId, MessageId, Заголовок, reply_markup,Истина);
	
КонецПроцедуры

Процедура ОткрытьВремя(ИмяБота, TelegramId, MessageId, Сообщение, Заголовок = "Выберите дату") Экспорт
	
	Если Сообщение = Неопределено Тогда
		
		Сообщение = Новый Структура("cmd,dateStart,date", "calendar", ТекущаяДата() - Дата(1,1,1), ТекущаяДата() - Дата(1,1,1));
	КонецЕсли;
	
	Если Сообщение.cmd = "calendar" Тогда
		
		КалендарьТЗ = ОбщийСервер.ПолучитьКалендарьЗаПериод(НачалоДня(Дата(1,1,1) + Макс(Сообщение.dateStart, Сообщение.date)), КонецМесяца(Дата(1,1,1) + Сообщение.date), Истина, Истина);
		
		ЗаписьJSON = СоздатьInlineKeyboard();
		
		ЗаписьJSON.ЗаписатьНачалоМассива();
		
		ДобавитьInlineКнопку(ЗаписьJSON, "<", JSONДанныеКалендаря("calendar", Сообщение.dateStart, НачалоМесяца(Дата(1,1,1) + Сообщение.date - 1) - Дата(1,1,1)));
		ДобавитьInlineКнопку(ЗаписьJSON, Формат(Дата(1,1,1) + Сообщение.date, "ДФ='MMM'"), JSONДанныеКалендаря("calendar", Сообщение.dateStart, Сообщение.date));
		ДобавитьInlineКнопку(ЗаписьJSON, ">", JSONДанныеКалендаря("calendar", Сообщение.dateStart, КонецМесяца(Дата(1,1,1) + Сообщение.date) + 1 - Дата(1,1,1)));
		
		ДобавитьInlineКнопку(ЗаписьJSON, "<", JSONДанныеКалендаря("calendar", Сообщение.dateStart, НачалоГода(НачалоГода(Дата(1,1,1) + Сообщение.date) - 1) - Дата(1,1,1)));
		ДобавитьInlineКнопку(ЗаписьJSON, Формат(Дата(1,1,1) + Сообщение.date, "ДФ='yyyy'"), JSONДанныеКалендаря("calendar", Сообщение.dateStart, Сообщение.date));
		ДобавитьInlineКнопку(ЗаписьJSON, ">", JSONДанныеКалендаря("calendar", Сообщение.dateStart, КонецГода(Дата(1,1,1) + Сообщение.date) + 1 - Дата(1,1,1)));
		
		ЗаписьJSON.ЗаписатьКонецМассива();
		
		ЗаписьJSON.ЗаписатьНачалоМассива();
		ДобавитьInlineКнопку(ЗаписьJSON, "Пн", 0);
		ДобавитьInlineКнопку(ЗаписьJSON, "Вт", 0);
		ДобавитьInlineКнопку(ЗаписьJSON, "Ср", 0);
		ДобавитьInlineКнопку(ЗаписьJSON, "Чт", 0);
		ДобавитьInlineКнопку(ЗаписьJSON, "Пт", 0);
		ДобавитьInlineКнопку(ЗаписьJSON, "Сб", 0);
		ДобавитьInlineКнопку(ЗаписьJSON, "Вс", 0);
		ЗаписьJSON.ЗаписатьКонецМассива();
		
		НомерНедели = Неопределено;
		МассивДней  = Неопределено;
		
		Для Каждого СтрокаКалендаря Из КалендарьТЗ Цикл
			
			Если Не НомерНедели = (СтрокаКалендаря.НомерНедели - 1) Тогда
				
				Если Не НомерНедели = Неопределено Тогда
					
					Для ДеньНедели = 0 По 6 Цикл
						Если МассивДней[ДеньНедели] = Неопределено Тогда
							
							ДобавитьInlineКнопку(ЗаписьJSON, " ", JSONДанныеКалендаря("calendar", Сообщение.dateStart, Сообщение.date));
						Иначе
							
							ДобавитьInlineКнопку(ЗаписьJSON, "" + День(МассивДней[ДеньНедели]), JSONДанныеКалендаря("timing", Сообщение.dateStart, МассивДней[ДеньНедели] - Дата(1,1,1)));
						КонецЕсли;
					КонецЦикла;
					
					ЗаписьJSON.ЗаписатьКонецМассива();
				КонецЕсли;
				
				ЗаписьJSON.ЗаписатьНачалоМассива();
				
				МассивДней  = Новый Массив(7);
				НомерНедели = СтрокаКалендаря.НомерНедели - 1;
			КонецЕсли;
			
			МассивДней[СтрокаКалендаря.ДеньНедели - 1] = СтрокаКалендаря.Дата;
		КонецЦикла;
		
		Для ДеньНедели = 0 По 6 Цикл
			Если МассивДней[ДеньНедели] = Неопределено Тогда
				ДобавитьInlineКнопку(ЗаписьJSON, " ", JSONДанныеКалендаря("calendar", Сообщение.dateStart, Сообщение.date));
			Иначе
				ДобавитьInlineКнопку(ЗаписьJSON, День(МассивДней[ДеньНедели]), JSONДанныеКалендаря("timing", Сообщение.dateStart, МассивДней[ДеньНедели] - Дата(1,1,1)));
			КонецЕсли;
		КонецЦикла;
		
		ЗаписьJSON.ЗаписатьКонецМассива();
		
		reply_markup = ДобавитьInlineКнопкуОтменить(ЗаписьJSON);
		
		ОтправитьВTelegramText(ИмяБота, TelegramId, MessageId, Заголовок, reply_markup,Истина);
		
	ИначеЕсли Сообщение.cmd = "timing" Тогда
		
		// Дату выбрали, выберем время
		
		ЗаписьJSON = СоздатьInlineKeyboard();
		
		ЗаписьJSON.ЗаписатьНачалоМассива();
		ДобавитьInlineКнопку(ЗаписьJSON, Формат(Дата(1,1,1) + Сообщение.date, "ДЛФ=DD"),"back");
		ЗаписьJSON.ЗаписатьКонецМассива();
		
		СчетчикКолонок = 1;
		МассивОткрыт   = Ложь;
		
		Для СчетчикЧасов = 4 По 23 Цикл
			
			Если СчетчикКолонок = 1 И
				Не МассивОткрыт Тогда
				
				МассивОткрыт   = Истина;
				ЗаписьJSON.ЗаписатьНачалоМассива();
			КонецЕсли;
			
			Если ДобавитьКнопкуВремени(Сообщение.dateStart, ЗаписьJSON, Формат(СчетчикЧасов, "ЧЦ=2; ЧВН=") + ":00", Сообщение.date + (СчетчикЧасов * 3600)) Тогда
				
				СчетчикКолонок = СчетчикКолонок + 1;
			КонецЕсли;
			
			Если СчетчикКолонок > 4 Тогда 
				
				ЗаписьJSON.ЗаписатьКонецМассива();
				МассивОткрыт = Ложь;
				СчетчикКолонок = 1;
			КонецЕсли;
			
		КонецЦикла;
		
		Если МассивОткрыт Тогда
			
			ЗаписьJSON.ЗаписатьКонецМассива();
		КонецЕсли;
		
		reply_markup = ДобавитьОсновныеInlineКнопки(ЗаписьJSON);
		
		ОтправитьВTelegramText(ИмяБота, TelegramId, MessageId, "Выберите время", reply_markup, Истина);
	КонецЕсли;
	
КонецПроцедуры

Функция ДобавитьInlineКнопку(JSON, Text, CallbackData, ОбщаяДлина = 50) Экспорт
	
	// ОбщаяДлина - используем как функцию где понадобится (где может создаваться много кнопок) контролировать ограничение по длине сообщения телеги 4096 символов
	Если ОбщаяДлина > 0 Тогда
		
		ОбщаяДлина = СтрДлина(Text) + СтрДлина(CallbackData) + ОбщаяДлина;
	КонецЕсли;
	
	Если ОбщаяДлина < 3000 Тогда
		
		JSON.ЗаписатьНачалоОбъекта();
		JSON.ЗаписатьИмяСвойства("text");
		JSON.ЗаписатьЗначение(Text);
		JSON.ЗаписатьИмяСвойства("callback_data");
		JSON.ЗаписатьЗначение(CallbackData);
		JSON.ЗаписатьКонецОбъекта();
	КонецЕсли;
	
	Возврат ОбщаяДлина;
	
КонецФункции

