#Область ЖурналированиеИсторииИПоследнееСообщение 

Процедура ДобавитьВИсториюЗапросов(ИмяБота,Сообщение) Экспорт
	
	МенеджерЗаписи = РегистрыСведений.TelegramИсторияЗапросов.СоздатьМенеджерЗаписи();
	МенеджерЗаписи.Период  = ТекущаяДата();
	МенеджерЗаписи.ИмяБота = ИмяБота; 
	
	Если Сообщение.Свойство("callback_query") Тогда
		
		Если Сообщение.callback_query.data = "back" Или
			Сообщение.callback_query.data = "cancel" Тогда
			
			Возврат;
		КонецЕсли;
		
		МенеджерЗаписи.TelegramId = Сообщение.callback_query.from.id;
		МенеджерЗаписи.Сообщение  = Новый ХранилищеЗначения(Сообщение.callback_query);
		
	ИначеЕсли Сообщение.Свойство("message") И
		Сообщение.message.Свойство("text") Тогда
		
		МенеджерЗаписи.TelegramId = Сообщение.message.chat.id;
		МенеджерЗаписи.Сообщение  = Новый ХранилищеЗначения(Сообщение.message);
	Иначе
		
		Возврат;
	КонецЕсли;
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
	"ВЫБРАТЬ
	|	TelegramТекущиеЗапросы.Стадия КАК Стадия
	|ИЗ
	|	РегистрСведений.TelegramТекущиеЗапросы КАК TelegramТекущиеЗапросы
	|ГДЕ
	|	TelegramТекущиеЗапросы.TelegramId = &TelegramId
	|	И TelegramТекущиеЗапросы.ИмяБота = &ИмяБота";
	
	Запрос.УстановитьПараметр("TelegramId", МенеджерЗаписи.TelegramId);
	Запрос.УстановитьПараметр("ИмяБота", МенеджерЗаписи.ИмяБота);
	
	Выборка = Запрос.Выполнить().Выбрать();
	
	Если Выборка.Следующий() Тогда
		
		МенеджерЗаписи.Стадия = Выборка.Стадия;
	КонецЕсли;
	
	МенеджерЗаписи.Записать(Истина);
	
КонецПроцедуры

Процедура ОчиститьИсториюЗапросов(ИмяБота, TelegramId) Экспорт
	
	НачатьТранзакцию(РежимУправленияБлокировкойДанных.Управляемый);
	
	Блокировка = Новый БлокировкаДанных;
	ЭлементБлокировки = Блокировка.Добавить("РегистрСведений.TelegramИсторияЗапросов");
	ЭлементБлокировки.Режим = РежимБлокировкиДанных.Исключительный;
	
	ЭлементБлокировки.УстановитьЗначение("TelegramId", TelegramId);
	ЭлементБлокировки.УстановитьЗначение("ИмяБота", ИмяБота);
	
	Блокировка.Заблокировать();
	
	НаборЗаписей = РегистрыСведений.TelegramИсторияЗапросов.СоздатьНаборЗаписей();
	НаборЗаписей.Отбор.ИмяБота.Установить(ИмяБота);
	НаборЗаписей.Отбор.TelegramId.Установить(TelegramId);
	НаборЗаписей.Записать();
	
	ЗафиксироватьТранзакцию();
	
КонецПроцедуры

Процедура УдалитьПоследнююЗаписьИстории(ИмяБота, TelegramId) Экспорт
	
	НачатьТранзакцию(РежимУправленияБлокировкойДанных.Управляемый);
	
	Блокировка = Новый БлокировкаДанных;
	ЭлементБлокировки = Блокировка.Добавить("РегистрСведений.TelegramИсторияЗапросов");
	ЭлементБлокировки.Режим = РежимБлокировкиДанных.Исключительный;
	
	ЭлементБлокировки.УстановитьЗначение("TelegramId", TelegramId);
	ЭлементБлокировки.УстановитьЗначение("ИмяБота", ИмяБота);
	
	Блокировка.Заблокировать();         
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
	"ВЫБРАТЬ
	|	TelegramИсторияЗапросов.Период КАК Период,
	|	TelegramИсторияЗапросов.TelegramId КАК TelegramId,
	|	TelegramИсторияЗапросов.ИмяБота КАК ИмяБота
	|ИЗ
	|	РегистрСведений.TelegramИсторияЗапросов.СрезПоследних(
	|			,
	|			TelegramId = &TelegramId
	|				И ИмяБота = &ИмяБота) КАК TelegramИсторияЗапросов";
	
	Запрос.УстановитьПараметр("TelegramId", TelegramId);
	Запрос.УстановитьПараметр("ИмяБота", ИмяБота);
	
	Выборка = Запрос.Выполнить().Выбрать();
	
	Если Не Выборка.Следующий() Тогда
		
		Возврат;
	КонецЕсли;
	
	МенеджерЗаписи = РегистрыСведений.TelegramИсторияЗапросов.СоздатьМенеджерЗаписи();
	ЗаполнитьЗначенияСвойств(МенеджерЗаписи, Выборка);
	МенеджерЗаписи.Удалить();
	
	ЗафиксироватьТранзакцию();
	
КонецПроцедуры

Функция ПолучитьПоследнееСообщение(ИмяБота, TelegramId) Экспорт
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
	"ВЫБРАТЬ
	|	TelegramПоследнееСообщение.Сообщение КАК Сообщение
	|ИЗ
	|	РегистрСведений.TelegramПоследнееСообщение КАК TelegramПоследнееСообщение
	|ГДЕ
	|	TelegramПоследнееСообщение.TelegramId = &TelegramId
	|	И TelegramПоследнееСообщение.ИмяБота = &ИмяБота";
	
	Запрос.УстановитьПараметр("TelegramId", TelegramId);
	Запрос.УстановитьПараметр("ИмяБота", ИмяБота);
	
	РезультатЗапроса = Запрос.Выполнить();
	
	ВыборкаДетальныеЗаписи = РезультатЗапроса.Выбрать();
	
	Пока ВыборкаДетальныеЗаписи.Следующий() Цикл
		
		Возврат ВыборкаДетальныеЗаписи.Сообщение; 
	КонецЦикла;                                
	
	Возврат "";
	
