Функция ПолучитьОтложенныйЗапрос(Идентификатор)
	
	Структура = Новый Структура("Команда,Стадия,Данные,ИмяБота,ОтветПользователя,ВремяЖизниЗапроса");
	
	НаборЗаписей = РегистрыСведений.TelegramОтложенныеЗапросы.СоздатьНаборЗаписей();
	НаборЗаписей.Отбор.Идентификатор.Установить(Идентификатор);
	НаборЗаписей.Прочитать();
	
	Если НаборЗаписей.Количество() = 1 Тогда
		
		МенеджерЗаписи = НаборЗаписей[0];
		
		Структура.Команда           = МенеджерЗаписи.Команда;
		Структура.Стадия            = МенеджерЗаписи.Стадия;
		Структура.ИмяБота           = МенеджерЗаписи.ИмяБота;
		Структура.Данные            = МенеджерЗаписи.Данные.Получить();
		//Структура.ОтветПользователя = МенеджерЗаписи.ОтветПользователя;	
		Структура.ВремяЖизниЗапроса = МенеджерЗаписи.ВремяЖизниЗапроса;
		
		НаборЗаписей.Очистить();
		НаборЗаписей.Записать(Истина);	
		
		Запрос = Новый Запрос;
		Запрос.Текст = 
		"ВЫБРАТЬ
		|	TelegramЗадачиНаПроверке.Задача КАК Задача,
		|	TelegramЗадачиНаПроверке.TelegramId КАК TelegramId,
		|	TelegramЗадачиНаПроверке.ИмяБота КАК ИмяБота,
		|	TelegramЗадачиНаПроверке.ИдентификаторОтложенногоЗапроса КАК ИдентификаторОтложенногоЗапроса,
		|	TelegramЗадачиНаПроверке.ДатаОкончания КАК ДатаОкончания,
		|	TelegramЗадачиНаПроверке.ДатаПроверки КАК ДатаПроверки
		|ИЗ
		|	РегистрСведений.TelegramЗадачиНаПроверке КАК TelegramЗадачиНаПроверке
		|ГДЕ
		|	TelegramЗадачиНаПроверке.ИдентификаторОтложенногоЗапроса = &ИдентификаторОтложенногоЗапроса";
		
		Запрос.УстановитьПараметр("ИдентификаторОтложенногоЗапроса", Идентификатор);
		
		РезультатЗапроса = Запрос.Выполнить();
		
		ВыборкаДетальныеЗаписи = РезультатЗапроса.Выбрать();
		
		Пока ВыборкаДетальныеЗаписи.Следующий() Цикл
			
			новМенеджер = РегистрыСведений.TelegramЗадачиНаПроверке.СоздатьМенеджерЗаписи();
			
			ЗаполнитьЗначенияСвойств(новМенеджер, ВыборкаДетальныеЗаписи);
			
			новМенеджер.ИдентификаторОтложенногоЗапроса = "";
			новМенеджер.Записать(Истина);
		КонецЦикла;
		
		Возврат Структура;
	КонецЕсли;
	
	Возврат Неопределено;
	
КонецФункции

Функция ПолучитьТекущийЗапрос(TelegramId, ИмяБота) Экспорт
	
	УстановитьПривилегированныйРежим(Истина);
	
	НачатьТранзакцию(РежимУправленияБлокировкойДанных.Управляемый);
	
	Блокировка = Новый БлокировкаДанных;
	ЭлементБлокировки = Блокировка.Добавить("РегистрСведений.TelegramТекущиеЗапросы");
	ЭлементБлокировки.Режим = РежимБлокировкиДанных.Исключительный;
	ЭлементБлокировки.УстановитьЗначение("TelegramId", TelegramId);
	ЭлементБлокировки.УстановитьЗначение("ИмяБота", ИмяБота);
	
	Блокировка.Заблокировать();        
	
	МенеджерЗаписи = РегистрыСведений.TelegramТекущиеЗапросы.СоздатьМенеджерЗаписи();
	МенеджерЗаписи.TelegramId = TelegramId;
	МенеджерЗаписи.ИмяБота = ИмяБота;
	МенеджерЗаписи.Прочитать();
	
	Если МенеджерЗаписи.Выбран() Тогда
		
		Если (ТекущаяДата() - МенеджерЗаписи.Время) > МенеджерЗаписи.ВремяЖизниЗапроса Тогда
			
			МенеджерЗаписи.Удалить();
			
			Telegram.ОчиститьИсториюЗапросов(ИмяБота, TelegramId);
			
			ОтправитьИнформационноеСообщение(TelegramId, "Истекло время ожидания ответа на запрос");
			
			ЗафиксироватьТранзакцию();
			
			Возврат Неопределено;
		КонецЕсли;
		
		Структура = Новый Структура("Команда,Стадия,Данные,ВремяЖизниЗапроса");
		Структура.Команда           = МенеджерЗаписи.Команда;
		Структура.Стадия            = МенеджерЗаписи.Стадия;
		Структура.Данные            = МенеджерЗаписи.Данные.Получить();	
		Структура.ВремяЖизниЗапроса = МенеджерЗаписи.ВремяЖизниЗапроса;
		
		ЗафиксироватьТранзакцию();
		
		Возврат Структура;
	КонецЕсли;
	
	Если ТранзакцияАктивна() Тогда
		
		ОтменитьТранзакцию();
	КонецЕсли;
	
	УстановитьПривилегированныйРежим(Ложь);
	
	Возврат Неопределено;
	
КонецФункции

Процедура УдалитьТекущийЗапрос(ИмяБота, TelegramId) Экспорт
	
	Если Не ИмяБота = null Тогда
		
		НачатьТранзакцию(РежимУправленияБлокировкойДанных.Управляемый);
		
		Блокировка = Новый БлокировкаДанных;
		ЭлементБлокировки = Блокировка.Добавить("РегистрСведений.TelegramТекущиеЗапросы");
		ЭлементБлокировки.Режим = РежимБлокировкиДанных.Исключительный;
		
		ЭлементБлокировки.УстановитьЗначение("ИмяБота", ИмяБота);
		ЭлементБлокировки.УстановитьЗначение("TelegramId", TelegramId);
		
		Блокировка.Заблокировать();
		
		МенеджерЗаписи = РегистрыСведений.TelegramТекущиеЗапросы.СоздатьМенеджерЗаписи();
		МенеджерЗаписи.TelegramId = TelegramId;
		МенеджерЗаписи.ИмяБота    = ИмяБота;
		МенеджерЗаписи.Удалить();
		
		ЗафиксироватьТранзакцию();
		
		ОчиститьИсториюЗапросов(ИмяБота, TelegramId);
	КонецЕсли;
	
КонецПроцедуры

Процедура ОбработатьОтложенныеЗапросы() Экспорт
	
	Отбор = Новый Структура("ИмяМетода,Состояние", "Telegram.ОбработатьОтложенныеЗапросы", СостояниеФоновогоЗадания.Активно);
	
	КолТекущихФоновыхЗаданий     = ФоновыеЗадания.ПолучитьФоновыеЗадания(Отбор).Количество();
	
	Если КолТекущихФоновыхЗаданий > 1 Тогда
		
		Возврат;
	КонецЕсли;	
	
	Пока Истина Цикл
		
		Попытка
			
			Запрос = Новый Запрос;
			Запрос.Текст = 
			"ВЫБРАТЬ
			|	TelegramТекущиеЗапросы.TelegramId КАК TelegramId,
			|	TelegramТекущиеЗапросы.Время КАК Время,
			|	TelegramТекущиеЗапросы.ВремяЖизниЗапроса КАК ВремяЖизниЗапроса,
			|	TelegramПоследнееСообщение.MessageId КАК MessageId,
			|	TelegramПоследнееСообщение.Сообщение КАК Сообщение,
			|	TelegramПоследнееСообщение.ИмяБота КАК ИмяБота
			|ИЗ
			|	РегистрСведений.TelegramТекущиеЗапросы КАК TelegramТекущиеЗапросы
			|		ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.TelegramПоследнееСообщение КАК TelegramПоследнееСообщение
			|		ПО (TelegramТекущиеЗапросы.TelegramId = TelegramПоследнееСообщение.TelegramId
			|				И TelegramТекущиеЗапросы.ИмяБота = TelegramПоследнееСообщение.ИмяБота)";
			
			РезультатЗапроса = Запрос.Выполнить();
			
			ВыборкаДетальныеЗаписи = РезультатЗапроса.Выбрать();
			
			Пока ВыборкаДетальныеЗаписи.Следующий() Цикл
				
				Если ВыборкаДетальныеЗаписи.Время + ВыборкаДетальныеЗаписи.ВремяЖизниЗапроса < ТекущаяДата() Тогда
					
					НачатьТранзакцию(РежимУправленияБлокировкойДанных.Управляемый);
					
					Блокировка = Новый БлокировкаДанных;
					ЭлементБлокировки = Блокировка.Добавить("РегистрСведений.TelegramТекущиеЗапросы");
					ЭлементБлокировки.Режим = РежимБлокировкиДанных.Исключительный;
					
					ЭлементБлокировки.УстановитьЗначение("TelegramId", ВыборкаДетальныеЗаписи.TelegramId);
					Блокировка.Заблокировать();  
					
					Telegram.УдалитьТекущийЗапрос(ВыборкаДетальныеЗаписи.ИмяБота, ВыборкаДетальныеЗаписи.TelegramId);
					
					МенеджерЗаписи = РегистрыСведений.TelegramПоследнееСообщение.СоздатьМенеджерЗаписи();
					МенеджерЗаписи.TelegramId = ВыборкаДетальныеЗаписи.TelegramId;
					МенеджерЗаписи.ИмяБота = ВыборкаДетальныеЗаписи.ИмяБота;
					
					МенеджерЗаписи.Удалить();
					
					Если Не ВыборкаДетальныеЗаписи.MessageId = NULL Тогда
						
						Если Лев(ВыборкаДетальныеЗаписи.Сообщение,20) = "Что было сделано за " Тогда
							
							// Завершим задачу    
							
							Сотрудник = ПолучитьСотрудникаПоTelegramId(ВыборкаДетальныеЗаписи.TelegramId);
							ДанныеЗадачи = ОбщийСервер.ПолучитьВыполняемуюРаботуБезКомментария(,Сотрудник);
							ОбщийСервер.СтопЗадачи(ДанныеЗадачи.Задача,Сотрудник,"Истекло время ожидания ответа");   
							ОтправитьВTelegramText(ВыборкаДетальныеЗаписи.ИмяБота,ВыборкаДетальныеЗаписи.TelegramId, ВыборкаДетальныеЗаписи.MessageId,"" + ВыборкаДетальныеЗаписи.Сообщение + Символы.ПС + Символы.ПС + "❗ Время ожидания ответа истекло, данные задачи были записаны без комментария. Нажмите /start",,Истина);
						Иначе
							
							ОтправитьВTelegramText(ВыборкаДетальныеЗаписи.ИмяБота,ВыборкаДетальныеЗаписи.TelegramId, ВыборкаДетальныеЗаписи.MessageId,"" + ВыборкаДетальныеЗаписи.Сообщение + Символы.ПС + Символы.ПС + "❗ Время ожидания ответа истекло нажмите /start",,Истина);
						КонецЕсли;					
					КонецЕсли;
					
					ЗафиксироватьТранзакцию();
				КонецЕсли;			
			КонецЦикла;
			
			Запрос = Новый Запрос;
			Запрос.Текст = 
			"ВЫБРАТЬ
			|	TelegramОтложенныеЗапросы.MessageId КАК MessageId,
			|	TelegramОтложенныеЗапросы.ИмяБота КАК ИмяБота,
			|	TelegramОтложенныеЗапросы.TelegramId КАК TelegramId,
			|	TelegramОтложенныеЗапросы.Время КАК Время,
			|	TelegramОтложенныеЗапросы.ВремяЖизниЗапроса КАК ВремяЖизниЗапроса,
			|	TelegramОтложенныеЗапросы.Сообщение КАК Сообщение,
			|	TelegramОтложенныеЗапросы.Отправлено КАК Отправлено,
			|	TelegramОтложенныеЗапросы.ДанныеОтложенногоЗапроса КАК ДанныеОтложенногоЗапроса,
			|	TelegramОтложенныеЗапросы.Идентификатор КАК Идентификатор,
			|	TelegramЗадачиНаПроверке.ДатаОкончания КАК ДатаОкончания,
			|	TelegramЗадачиНаПроверке.Задача КАК Задача,
			|	TelegramОтложенныеЗапросы.Команда КАК Команда,
			|	TelegramОтложенныеЗапросы.Попытка КАК Попытка,
			|	TelegramОтложенныеЗапросы.Данные КАК Данные
			|ИЗ
			|	РегистрСведений.TelegramОтложенныеЗапросы КАК TelegramОтложенныеЗапросы
			|		ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.TelegramЗадачиНаПроверке КАК TelegramЗадачиНаПроверке
			|		ПО TelegramОтложенныеЗапросы.Идентификатор = TelegramЗадачиНаПроверке.ИдентификаторОтложенногоЗапроса
			|
			|УПОРЯДОЧИТЬ ПО
			|	Время УБЫВ";
			
			РезультатЗапроса = Запрос.Выполнить();
			
			отлЗапрос = РезультатЗапроса.Выбрать();
			
			Отправленные = Новый Массив;
			
			Пока отлЗапрос.Следующий() Цикл
				
				Если отлЗапрос.Отправлено И отлЗапрос.Время + отлЗапрос.ВремяЖизниЗапроса < ТекущаяДата() Тогда
					
					очистка = РегистрыСведений.TelegramОтложенныеЗапросы.СоздатьНаборЗаписей();
					очистка.Отбор.ИмяБота.Установить(отлЗапрос.ИмяБота);
					очистка.Отбор.TelegramId.Установить(отлЗапрос.TelegramId);
					очистка.Отбор.MessageId.Установить(отлЗапрос.MessageId);
					очистка.Отбор.Отправлено.Установить(Истина);
					
					очистка.Записать(Истина);
					
					Если отлЗапрос.ДатаОкончания = Дата(1,1,1)  И отлЗапрос.Команда = "ПроверкаИсполненияЗадачи" 
						И Отправленные.Найти(отлЗапрос.Задача) = Неопределено Тогда
						
						// завершим задачу
						Отправленные.Добавить(отлЗапрос.Задача);
						
						Запрос = Новый Запрос;
						Запрос.Текст = 
						"ВЫБРАТЬ
						|	ПроделаннаяРаботаСрезПоследних.Задача КАК Задача,
						|	ПроделаннаяРаботаСрезПоследних.Сотрудник КАК Сотрудник,
						|	ПроделаннаяРаботаСрезПоследних.Окончание КАК Окончание,
						|	ПроделаннаяРаботаСрезПоследних.Длительность КАК Длительность,
						|	ПроделаннаяРаботаСрезПоследних.Период КАК Период
						|ИЗ
						|	РегистрСведений.ПроделаннаяРабота.СрезПоследних(
						|			,
						|			Сотрудник = &Сотрудник
						|				И Задача = &Задача) КАК ПроделаннаяРаботаСрезПоследних
						|ГДЕ
						|	ПроделаннаяРаботаСрезПоследних.Окончание = ДАТАВРЕМЯ(1, 1, 1, 0, 0, 0)";
						
						Запрос.УстановитьПараметр("Сотрудник", отлЗапрос.Задача.Исполнитель);
						Запрос.УстановитьПараметр("Задача", отлЗапрос.Задача);
						
						РезультатЗапроса = Запрос.Выполнить();
						
						ВыборкаДетальныеЗаписи = РезультатЗапроса.Выбрать();
						
						Пока ВыборкаДетальныеЗаписи.Следующий() Цикл
							
							Если ВыборкаДетальныеЗаписи.Задача = отлЗапрос.Задача Тогда
								
								МенеджерЗаписи = РегистрыСведений.ПроделаннаяРабота.СоздатьМенеджерЗаписи();
								ЗаполнитьЗначенияСвойств(МенеджерЗаписи, ВыборкаДетальныеЗаписи);
								
								Если ВыборкаДетальныеЗаписи.Период < ТекущаяДата() - 60*45 Тогда
									
									МенеджерЗаписи.Окончание = ТекущаяДата() - 60*45;
								Иначе
									МенеджерЗаписи.Окончание = ВыборкаДетальныеЗаписи.Период + 60;
								КонецЕсли;
								
								МенеджерЗаписи.Записать(Истина);
								
								регистрПроверки = РегистрыСведений.TelegramЗадачиНаПроверке.СоздатьНаборЗаписей();
								регистрПроверки.Отбор.ИмяБота.Установить(отлЗапрос.ИмяБота);
								регистрПроверки.Отбор.TelegramId.Установить(отлЗапрос.TelegramId);
								регистрПроверки.Отбор.Задача.Установить(отлЗапрос.Задача);
								
								регистрПроверки.Прочитать();
								
								Для Каждого СтрокаПроверки Из регистрПроверки Цикл
									
									СтрокаПроверки.ДатаОкончания = ТекущаяДата();
								КонецЦикла;
								
								регистрПроверки.Записать(Истина);
							КонецЕсли;
						КонецЦикла;	
						
						НачатьТранзакцию();     
						
						Ид = ПолучитьИдентификаторОтложенногоЗапроса();
						Данные = отлЗапрос.ДанныеОтложенногоЗапроса.Получить();
						
						СообщениеТг = отлЗапрос.Сообщение + Символы.ПС + Символы.ПС + "❗ Время ожидания ответа истекло, время по задаче было сброшено, вы можете возобновить задачу в течении 3х часов, в следующем сообщении." + Символы.ПС + "В случае если вы запустите другую задачу время останется сброшенным (-45 минут)";
						
						Запрос = Новый Запрос;
						Запрос.Текст = 
						"ВЫБРАТЬ
						|	TelegramОтложенныеЗапросы.Сообщение КАК Сообщение
						|ИЗ
						|	РегистрСведений.TelegramОтложенныеЗапросы КАК TelegramОтложенныеЗапросы
						|ГДЕ
						|	TelegramОтложенныеЗапросы.Команда ПОДОБНО ""ПроверкаИсполненияЗадачи""
						|	И TelegramОтложенныеЗапросы.TelegramId = &TelegramId
						|	И TelegramОтложенныеЗапросы.ИмяБота = &ИмяБота
						|	И TelegramОтложенныеЗапросы.Отправлено
						|	И TelegramОтложенныеЗапросы.Сообщение ПОДОБНО &СообщениеТг";
						
						Запрос.УстановитьПараметр("TelegramId", отлЗапрос.TelegramId);
						Запрос.УстановитьПараметр("ИмяБота", отлЗапрос.ИмяБота);                           				
						Запрос.УстановитьПараметр("СообщениеТг", СообщениеТг); 
						
						РезультатЗапроса = Запрос.Выполнить();
						
						Если Не РезультатЗапроса.Пустой() Тогда
							
							Продолжить;
						КонецЕсли;					
						
						ОтправитьВTelegramText(отлЗапрос.ИмяБота, отлЗапрос.TelegramId, отлЗапрос.MessageId, СообщениеТг,,Истина);				   			
						
						СтрокаИнтернетОтвета = "&#128293;&#128293;&#128293; Задача была остановлена " + Данные.Задача  + Символы.ПС + Символы.ПС + "<b>Возобновить выполнение задачи?</b>";
						
						ДанныеОтложенногоЗапроса = Новый Структура("СтрокаИнтернетОтвета,reply_markup");
						
						IK = СоздатьInlineKeyboard();
						
						IK.ЗаписатьНачалоМассива();
						ДобавитьInlineКнопку(IK, "✔️ Да","{""cmd"":""stoped_y"",""deffered"":""" + Ид + """}");
						ДобавитьInlineКнопку(IK, "❌ Нет","{""cmd"":""stoped_n"",""deffered"":""" + Ид + """}");
						IK.ЗаписатьКонецМассива();
						
						reply_markup = ЗавершитьInlineKeyboard(IK);
						
						ДанныеОтложенногоЗапроса.СтрокаИнтернетОтвета = СтрокаИнтернетОтвета;
						ДанныеОтложенногоЗапроса.reply_markup = reply_markup;
						
						Параметры = Новый Структура("ИмяБота,TelegramId,Команда,Стадия,Данные,ВремяЖизниЗапроса,Сообщение,ИдентификаторЗапроса,ДанныеОтложеннойОтправки",
						отлЗапрос.ИмяБота,
						отлЗапрос.TelegramId,
						"ПроверкаИсполненияЗадачи",
						1,
						Новый Структура("Задача",Данные.Задача),
						3*3600,
						СообщениеТг,
						Ид,
						ДанныеОтложенногоЗапроса);
						
						ДобавитьВОтложенныйЗапрос(Параметры);			
						ЗафиксироватьТранзакцию();
					Иначе
						
						Если отлЗапрос.Команда = "ПроверкаИсполненияЗадачи" Тогда
							
							// Удалим просроченную на возобновление задачу
							регистрПроверки = РегистрыСведений.TelegramЗадачиНаПроверке.СоздатьНаборЗаписей();
							регистрПроверки.Отбор.ИмяБота.Установить(отлЗапрос.ИмяБота);
							регистрПроверки.Отбор.TelegramId.Установить(отлЗапрос.TelegramId);
							
							регистрПроверки.Прочитать();
							
							регистрПроверки.Очистить();								
							регистрПроверки.Записать(Истина);
						КонецЕсли;
						ОтправитьВTelegramText(отлЗапрос.ИмяБота, отлЗапрос.TelegramId, отлЗапрос.MessageId, отлЗапрос.Сообщение + Символы.ПС + Символы.ПС + "❗ Время ожидания ответа истекло нажмите /start",,Истина);				   			
					КонецЕсли;									
				ИначеЕсли Не отлЗапрос.Отправлено И отлЗапрос.Время < ТекущаяДата() И Отправленные.Найти(отлЗапрос.Задача) = Неопределено Тогда
					
					ДанныеОтложенногоЗапроса = отлЗапрос.ДанныеОтложенногоЗапроса.Получить();
					
					Если отлЗапрос.Команда = "ОтложеннаяЗадача" Тогда
						
						текЗадача = отлЗапрос.Данные.Получить().Задача;
						
						Если текЗадача.Проведен Тогда
							
							РегистрОтложенногоЗапроса = РегистрыСведений.TelegramОтложенныеЗапросы.СоздатьНаборЗаписей();
							РегистрОтложенногоЗапроса.Отбор.Идентификатор.Установить(отлЗапрос.Идентификатор);
							РегистрОтложенногоЗапроса.Прочитать();
							
							РегистрОтложенногоЗапроса.Очистить();
							РегистрОтложенногоЗапроса.Записать();
							Продолжить;
						КонецЕсли;						
						
						Запрос = Новый Запрос;
						Запрос.Текст = 
						"ВЫБРАТЬ
						|	ПроделаннаяРабота.Окончание КАК Окончание
						|ИЗ
						|	РегистрСведений.ПроделаннаяРабота КАК ПроделаннаяРабота
						|ГДЕ
						|	ПроделаннаяРабота.Задача = &Задача
						|	И (НЕ ПроделаннаяРабота.Длительность = ДАТАВРЕМЯ(1, 1, 1)
						|				И НЕ ПроделаннаяРабота.Задача.Проведен
						|			ИЛИ НЕ ПроделаннаяРабота.Задача.Проведен)";
						
						Запрос.УстановитьПараметр("Задача", текЗадача);
						
						Если Не Запрос.Выполнить().Пустой() Тогда
							
							РегистрОтложенногоЗапроса = РегистрыСведений.TelegramОтложенныеЗапросы.СоздатьНаборЗаписей();
							РегистрОтложенногоЗапроса.Отбор.Идентификатор.Установить(отлЗапрос.Идентификатор);
							РегистрОтложенногоЗапроса.Прочитать();
							
							РегистрОтложенногоЗапроса.Очистить();
							РегистрОтложенногоЗапроса.Записать();
							Продолжить;
						КонецЕсли;
					КонецЕсли;			
					
					MessageId = ОтправитьВTelegramText(отлЗапрос.ИмяБота, отлЗапрос.TelegramId, 0,ДанныеОтложенногоЗапроса.СтрокаИнтернетОтвета,ДанныеОтложенногоЗапроса.reply_markup,Истина,отлЗапрос.Идентификатор,?(отлЗапрос.Попытка > 10,Истина,Ложь));
					
					Если MessageId > 0 Тогда
						
						РегистрОтложенногоЗапроса = РегистрыСведений.TelegramОтложенныеЗапросы.СоздатьНаборЗаписей();
						РегистрОтложенногоЗапроса.Отбор.Идентификатор.Установить(отлЗапрос.Идентификатор);
						РегистрОтложенногоЗапроса.Прочитать();
						
						Если РегистрОтложенногоЗапроса.Количество() > 0 Тогда
							
							Для Каждого текРегистр Из РегистрОтложенногоЗапроса Цикл
								
								текРегистр.MessageId = MessageId;
								текРегистр.Отправлено = Истина;
							КонецЦикла;
							
							РегистрОтложенногоЗапроса.Записать(Истина);
						КонецЕсли;     
						
						Отправленные.Добавить(отлЗапрос.Задача);
					Иначе
						
						РегистрОтложенногоЗапроса = РегистрыСведений.TelegramОтложенныеЗапросы.СоздатьНаборЗаписей();
						РегистрОтложенногоЗапроса.Отбор.Идентификатор.Установить(отлЗапрос.Идентификатор);
						РегистрОтложенногоЗапроса.Прочитать();
						
						Если РегистрОтложенногоЗапроса.Количество() = 1 Тогда
							
							РегистрОтложенногоЗапроса[0].Попытка = РегистрОтложенногоЗапроса[0].Попытка + 1;					
							РегистрОтложенногоЗапроса.Записать(Истина);
						КонецЕсли;     										
					КонецЕсли;           			
				КонецЕсли;
			КонецЦикла;
			
		Исключение
			
			ЗаписьЖурналаРегистрации("Telegram.ОбработатьОтложенныеЗапросы", УровеньЖурналаРегистрации.Информация,,,ОписаниеОшибки());
		КонецПопытки;     
	КонецЦикла;
	
КонецПроцедуры

Процедура УдалитьОтложенныйЗапрос(Идентификатор)
	
	ОтложенныйЗапрос = РегистрыСведений.TelegramОтложенныеЗапросы.СоздатьНаборЗаписей();
	ОтложенныйЗапрос.Отбор.Отправлено.Установить(Ложь);
	
	ОтложенныйЗапрос.Отбор.Идентификатор.Установить(Идентификатор);
	
	ОтложенныйЗапрос.Записать(Истина);
	
	ПроверкаЗадачи = РегистрыСведений.TelegramЗадачиНаПроверке.СоздатьНаборЗаписей();
	ПроверкаЗадачи.Отбор.ИдентификаторОтложенногоЗапроса.Установить(Идентификатор);
	
	ПроверкаЗадачи.Записать(Истина);	
	
КонецПроцедуры

Процедура ДобавитьОтложенныйЗапросФайлов(Задача,TelegramId) Экспорт
	
	ИмяБота = ПолучитьИмяБота();
	
	ДанныеОтложенногоЗапроса = Новый Структура("СтрокаИнтернетОтвета,reply_markup");
	
	НачатьТранзакцию();     
	
	Ид = ПолучитьИдентификаторОтложенногоЗапроса();
	
	СтрокаИнтернетОтвета = "К задаче " + Задача +  " прикреплены файлы:" + Символы.ПС;
	
	IK = СоздатьInlineKeyboard();
	
	IK.ЗаписатьНачалоМассива();
	ДобавитьInlineКнопку(IK, "Скачать файлы", "deffered:" + Ид);
	IK.ЗаписатьКонецМассива();
	
	IK.ЗаписатьНачалоМассива();
	ДобавитьInlineКнопку(IK, "❌ Нет", "cancelquery");
	IK.ЗаписатьКонецМассива();
	
	reply_markup = ЗавершитьInlineKeyboard(IK);
	
	ДанныеОтложенногоЗапроса.СтрокаИнтернетОтвета = СтрокаИнтернетОтвета;
	ДанныеОтложенногоЗапроса.reply_markup = reply_markup;
	
	Параметры = Новый Структура("ИмяБота,TelegramId,Команда,Стадия,Данные,ВремяЖизниЗапроса,Сообщение,ИдентификаторЗапроса,ДанныеОтложеннойОтправки",
	ИмяБота,
	TelegramId,
	"ПросмотрФайлов",
	0,
	Новый Структура("Задача",Задача),
	7200,
	СтрокаИнтернетОтвета,
	Ид,
	ДанныеОтложенногоЗапроса);
	
	ДобавитьВОтложенныйЗапрос(Параметры);	         
	ЗафиксироватьТранзакцию();
	
	
КонецПроцедуры

Функция ПолучитьИдентификаторОтложенногоЗапроса() Экспорт
	
	Пока Истина Цикл
		
		НовыйИдентификатор = Новый УникальныйИдентификатор();		
		НовыйИдентификатор = Лев(СтрЗаменить(Строка(НовыйИдентификатор),"-",""),10);
		
		Запрос = Новый Запрос;
		Запрос.Текст = 
		"ВЫБРАТЬ
		|	TelegramОтложенныеЗапросы.Идентификатор КАК Идентификатор
		|ИЗ
		|	РегистрСведений.TelegramОтложенныеЗапросы КАК TelegramОтложенныеЗапросы
		|ГДЕ
		|	TelegramОтложенныеЗапросы.Идентификатор = &Идентификатор";
		
		Запрос.УстановитьПараметр("Идентификатор", НовыйИдентификатор);
		
		РезультатЗапроса = Запрос.Выполнить();
		
		Если РезультатЗапроса.Пустой() Тогда
			
			Возврат НовыйИдентификатор;
		КонецЕсли;
	КонецЦикла;
	
КонецФункции

